            <fr:title text="Retract">Retract</fr:title>
            <fr:taxon>Definition</fr:taxon>
            <fr:meta name="source">
  
  
  <fr:link href="https://git.sr.ht/~jonsterling/agda-erct/tree/main/item/agda/erct-0025.agda" type="external">erct-0025.agda</fr:link>
</fr:meta>
          </fr:frontmatter>
          <fr:mainmatter>
            <fr:p>When <fr:tex display="inline"><![CDATA[s\colon  A\to  B]]></fr:tex> is a section of <fr:tex display="inline"><![CDATA[r\colon  B\to  A]]></fr:tex>, we say that <fr:tex display="inline"><![CDATA[A]]></fr:tex> is a <fr:em><fr:strong>retract</fr:strong></fr:em> of <fr:tex display="inline"><![CDATA[B]]></fr:tex>.</fr:p>
          </fr:mainmatter>
        </fr:tree>
        <fr:tree show-metadata="true" expanded="false" toc="false" numbered="false">
          <fr:frontmatter>
            <fr:authors>
              <fr:author>
                <fr:link href="foreign-erct-jonmsterling.xml" title="Jon Sterling" addr="//erct/jonmsterling" type="local">Jon Sterling</fr:link>
              </fr:author>
            </fr:authors>
            <fr:date>
              <fr:year>2023</fr:year>
              <fr:month>12</fr:month>
              <fr:day>20</fr:day>
            </fr:date>
            <fr:anchor>12004</fr:anchor>
            <fr:addr type="user">//erct/erct-001M</fr:addr>
            <fr:route>foreign-erct-erct-001M.xml</fr:route>
            <fr:title text="Dependent sum of propositions">Dependent sum of <fr:link href="foreign-erct-erct-001I.xml" title="Proposition" addr="//erct/erct-001I" type="local">propositions</fr:link></fr:title>
            <fr:taxon>Lemma</fr:taxon>
            <fr:meta name="source">
  
  
  <fr:link href="https://git.sr.ht/~jonsterling/agda-erct/tree/main/item/agda/erct-001M.agda" type="external">erct-001M.agda</fr:link>
</fr:meta>
          </fr:frontmatter>
          <fr:mainmatter><fr:p>If <fr:tex display="inline"><![CDATA[A]]></fr:tex> is a <fr:link href="foreign-erct-erct-001I.xml" title="Proposition" addr="//erct/erct-001I" type="local">proposition</fr:link> and <fr:tex display="inline"><![CDATA[B\colon  A\to  \mathsf {Type}]]></fr:tex> is family of <fr:link href="foreign-erct-erct-001I.xml" title="Proposition" addr="//erct/erct-001I" type="local">propositions</fr:link>, then the dependent sum <fr:tex display="inline"><![CDATA[\mathchoice {\textstyle \sum _{
 \mathopen {}\left \lparen x:A\right \rparen \mathclose {}
}}{\textstyle \sum _{
 \mathopen {}\left \lparen x:A\right \rparen \mathclose {}
}}{\scriptstyle \sum _{
 \mathopen {}\left \lparen x:A\right \rparen \mathclose {}
}}{\scriptscriptstyle \sum _{
 \mathopen {}\left \lparen x:A\right \rparen \mathclose {}
}}{Bx}]]></fr:tex> is a <fr:link href="foreign-erct-erct-001I.xml" title="Proposition" addr="//erct/erct-001I" type="local">proposition</fr:link>.</fr:p>
 
   
   <fr:tree show-metadata="false" toc="false"><fr:frontmatter><fr:authors><fr:author><fr:link href="foreign-erct-jonmsterling.xml" title="Jon Sterling" addr="//erct/jonmsterling" type="local">Jon Sterling</fr:link></fr:author></fr:authors><fr:date><fr:year>2023</fr:year><fr:month>12</fr:month><fr:day>20</fr:day></fr:date><fr:anchor>6696</fr:anchor><fr:addr type="machine">//erct/unstable/441</fr:addr><fr:route>foreign-erct-unstable-441.xml</fr:route><fr:title text="" /><fr:taxon>Proof</fr:taxon></fr:frontmatter><fr:mainmatter>
  <fr:p>We fix pairs 
 <fr:tex display="inline"><![CDATA[\mathopen {}\left \lparen a,b\right \rparen \mathclose {}]]></fr:tex>
 and 
 <fr:tex display="inline"><![CDATA[\mathopen {}\left \lparen a',b'\right \rparen \mathclose {}]]></fr:tex>
 in <fr:tex display="inline"><![CDATA[\mathchoice {\textstyle \sum _{
 \mathopen {}\left \lparen x:A\right \rparen \mathclose {}
}}{\textstyle \sum _{
 \mathopen {}\left \lparen x:A\right \rparen \mathclose {}
}}{\scriptstyle \sum _{
 \mathopen {}\left \lparen x:A\right \rparen \mathclose {}
}}{\scriptscriptstyle \sum _{
 \mathopen {}\left \lparen x:A\right \rparen \mathclose {}
}}{Bx}]]></fr:tex>. By <fr:link href="foreign-erct-erct-0035.xml" title="Covariant sum of a left-cloven family of path objects" addr="//erct/erct-0035" type="local">Definition <fr:contextual-number addr="//erct/erct-0035" /></fr:link> via <fr:link href="foreign-erct-erct-0017.xml" title="The intrinsic left cleaving of a family of path objects" addr="//erct/erct-0017" type="local">Example <fr:contextual-number addr="//erct/erct-0017" /></fr:link>, it suffices to exhibit identifications <fr:tex display="inline"><![CDATA[p\colon  a = a']]></fr:tex> and <fr:tex display="inline"><![CDATA[q\colon  p_* b = b']]></fr:tex>. These are given respectively by our assumptions that <fr:tex display="inline"><![CDATA[A]]></fr:tex> and <fr:tex display="inline"><![CDATA[Ba']]></fr:tex> are <fr:link href="foreign-erct-erct-001I.xml" title="Proposition" addr="//erct/erct-001I" type="local">propositions</fr:link>.</fr:p>
</fr:mainmatter></fr:tree>
 
</fr:mainmatter>
