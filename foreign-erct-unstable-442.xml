          <fr:mainmatter><fr:p>The <fr:link href="foreign-erct-erct-004D.xml" title="Product of a family of reflexive graphs" addr="//erct/erct-004D" type="local">product</fr:link> of a family <fr:tex display="inline"><![CDATA[\mathcal {B}\colon  A \to  \mathsf {PathObj}]]></fr:tex> <fr:link href="foreign-erct-erct-0010.xml" title="Path object" addr="//erct/erct-0010" type="local">path objects</fr:link> is a <fr:link href="foreign-erct-erct-001C.xml" title="Dependent product of path objects" addr="//erct/erct-001C" type="local">path object</fr:link>.</fr:p>
 
   
   <fr:tree show-metadata="false" toc="false"><fr:frontmatter><fr:authors><fr:author><fr:link href="foreign-erct-jonmsterling.xml" title="Jon Sterling" addr="//erct/jonmsterling" type="local">Jon Sterling</fr:link></fr:author></fr:authors><fr:date><fr:year>2023</fr:year><fr:month>12</fr:month><fr:day>20</fr:day></fr:date><fr:anchor>1478</fr:anchor><fr:addr type="machine">//erct/unstable/439</fr:addr><fr:route>foreign-erct-unstable-439.xml</fr:route><fr:title text="" /><fr:taxon>Proof</fr:taxon></fr:frontmatter><fr:mainmatter>
