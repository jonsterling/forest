root="false"><fr:frontmatter><fr:anchor>4800</fr:anchor><fr:addr>jms-00MG</fr:addr><fr:route>jms-00MG.xml</fr:route><fr:title>Enumerability and countability</fr:title><fr:date><fr:year>2024</fr:year><fr:month>1</fr:month><fr:day>29</fr:day></fr:date><fr:authors><fr:author><fr:link
