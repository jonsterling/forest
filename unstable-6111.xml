            <fr:title text="Kleene’s theorem">Kleene’s theorem</fr:title>
            <fr:taxon>Theorem</fr:taxon>
          </fr:frontmatter>
          <fr:mainmatter><fr:p>A <fr:link href="jms-016M.xml" title="Formal language" addr="jms-016M" type="local">formal language</fr:link> is <fr:link href="jms-017Y.xml" title="Regular language" addr="jms-017Y" type="local">regular</fr:link> if and only if it is <fr:link href="jms-0185.xml" title="Automatical language" addr="jms-0185" type="local">automatical</fr:link>.</fr:p>
 
   
   <fr:tree show-metadata="false" toc="false"><fr:frontmatter><fr:authors><fr:author><fr:link href="jonmsterling.xml" title="Jon Sterling" addr="jonmsterling" type="local">Jon Sterling</fr:link></fr:author></fr:authors><fr:date><fr:year>2025</fr:year><fr:month>2</fr:month><fr:day>16</fr:day></fr:date><fr:anchor>7384</fr:anchor><fr:addr type="machine">unstable/6110</fr:addr><fr:route>unstable-6110.xml</fr:route><fr:title text="" /><fr:taxon>Proof</fr:taxon></fr:frontmatter><fr:mainmatter>
 <fr:p>By <fr:link href="jms-018A.xml" title="All regular languages are automatical" addr="jms-018A" type="local">Corollary <fr:contextual-number addr="jms-018A" /></fr:link> and <fr:link href="jms-0183.xml" title="Decompilation of NFAs" addr="jms-0183" type="local">Corollary <fr:contextual-number addr="jms-0183" /></fr:link>.</fr:p>
</fr:mainmatter></fr:tree>
 
</fr:mainmatter>
