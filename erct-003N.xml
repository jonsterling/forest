root="false"><fr:frontmatter><fr:anchor>7046</fr:anchor><fr:taxon>Lemma</fr:taxon><fr:addr>erct-002D</fr:addr><fr:route>erct-002D.xml</fr:route><fr:title>From <fr:link
href="erct-000U.xml"
type="local"
addr="erct-000U">biinverses</fr:link> to <fr:link
href="erct-000X.xml"
type="local"
addr="erct-000X">quasi-inverses</fr:link></fr:title><fr:date><fr:year>2023</fr:year><fr:month>12</fr:month><fr:day>30</fr:day></fr:date><fr:authors><fr:author><fr:link
href="jonmsterling.xml"
type="local"
addr="jonmsterling">Jon Sterling</fr:link></fr:author></fr:authors><fr:meta
name="source">
  
  
  <fr:link
href="https://git.sr.ht/~jonsterling/agda-erct/tree/main/item/agda/erct-002D.agda"
type="external">erct-002D.agda</fr:link>
</fr:meta></fr:frontmatter><fr:mainmatter><fr:p>Let <fr:tex>f \colon  A \to  B</fr:tex> be <fr:link
href="erct-000U.xml"
type="local"
addr="erct-000U">biinvertible</fr:link> with <fr:tex>s,r \colon  B \to  A</fr:tex> and <fr:tex>h_s \colon  f  \circ  s  \sim   1_{ B }</fr:tex> and <fr:tex>h_r \colon  r \circ  f =  1_{ A }</fr:tex>. Then we may define a homotopy <fr:tex>h'  \colon  s \circ  f  \sim   1_{ A }</fr:tex> exhibiting <fr:tex>s \colon  B \to  A</fr:tex> as a retraction of <fr:tex>f \colon  A \to  B</fr:tex>. Therefore, we may define a <fr:link
href="erct-000X.xml"
type="local"
addr="erct-000X">quasi-inverse</fr:link> to <fr:tex>f</fr:tex> tracked by <fr:tex>s \colon  B \to  A</fr:tex>.</fr:p>
 
   
   <fr:tree
xmlns:fr="http://www.jonmsterling.com/jms-005P.xml"
toc="false"
numbered="true"
show-heading="true"
show-metadata="false"
expanded="true"
root="false"><fr:frontmatter><fr:anchor>2035</fr:anchor><fr:taxon>Proof</fr:taxon><fr:addr>#344</fr:addr><fr:route>unstable-344.xml</fr:route><fr:date><fr:year>2023</fr:year><fr:month>12</fr:month><fr:day>30</fr:day></fr:date><fr:authors><fr:author><fr:link
href="jonmsterling.xml"
type="local"
addr="jonmsterling">Jon Sterling</fr:link></fr:author></fr:authors><fr:parent>erct-002D</fr:parent></fr:frontmatter><fr:mainmatter>
 <fr:p>We have <fr:tex>s \circ  f  \sim  r \circ  f  \circ  s \circ  f</fr:tex> by <fr:tex>h_r</fr:tex> and <fr:tex>r \circ  f  \circ  s \circ  f \sim  r  \circ  f</fr:tex> by <fr:tex>h_s</fr:tex> and <fr:tex>r \circ  f  \sim   1_{ A }</fr:tex> by <fr:tex>h_r</fr:tex>.</fr:p>
</fr:mainmatter></fr:tree>
 
