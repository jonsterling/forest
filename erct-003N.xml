type="external">erct-003C.agda</fr:link>
</fr:meta></fr:frontmatter><fr:mainmatter><fr:p>Any <fr:link
href="erct-000X.xml"
type="local"
addr="erct-000X">quasi-invertible</fr:link> map <fr:tex>f \colon  A \to  B</fr:tex> is <fr:link
href="erct-000X.xml"
type="local"
addr="erct-000X">biinvertible</fr:link>.</fr:p>
 
   
   <fr:tree
xmlns:fr="http://www.jonmsterling.com/jms-005P.xml"
toc="false"
numbered="true"
show-heading="true"
show-metadata="false"
expanded="true"
root="false"><fr:frontmatter><fr:anchor>7032</fr:anchor><fr:taxon>Proof</fr:taxon><fr:addr>#321</fr:addr><fr:route>unstable-321.xml</fr:route><fr:date><fr:year>2024</fr:year><fr:month>1</fr:month><fr:day>3</fr:day></fr:date><fr:authors><fr:author><fr:link
href="jonmsterling.xml"
type="local"
addr="jonmsterling">Jon Sterling</fr:link></fr:author></fr:authors><fr:parent>erct-003C</fr:parent></fr:frontmatter><fr:mainmatter>
 <fr:p>The <fr:link
href="erct-000X.xml"
type="local"
addr="erct-000X">quasi-inverse</fr:link> to <fr:tex>f</fr:tex> is simultaneously a <fr:link
href="erct-000Y.xml"
type="local"
addr="erct-000Y">section</fr:link> and a <fr:link
href="erct-000Y.xml"
type="local"
addr="erct-000Y">retraction</fr:link>.</fr:p>
</fr:mainmatter></fr:tree>
 
</fr:mainmatter></fr:tree><fr:tree
xmlns:fr="http://www.jonmsterling.com/jms-005P.xml"
