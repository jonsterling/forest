expanded="true"
root="false"><fr:frontmatter><fr:anchor>2571</fr:anchor><fr:taxon>Definition</fr:taxon><fr:addr>erct-000V</fr:addr><fr:route>erct-000V.xml</fr:route><fr:title>Equivalence of types</fr:title><fr:date><fr:year>2023</fr:year><fr:month>12</fr:month><fr:day>19</fr:day></fr:date><fr:authors><fr:author><fr:link
href="jonmsterling.xml"
type="local"
addr="jonmsterling">Jon Sterling</fr:link></fr:author></fr:authors><fr:meta
name="source">
  
  
  <fr:link
href="https://git.sr.ht/~jonsterling/agda-erct/tree/main/item/agda/erct-000V.agda"
type="external">erct-000V.agda</fr:link>
</fr:meta></fr:frontmatter><fr:mainmatter><fr:p>An <fr:em><fr:strong>equivalence</fr:strong></fr:em> from <fr:tex>A</fr:tex> to <fr:tex>B</fr:tex> is defined to be a function <fr:tex>A  \to  B</fr:tex> equipped with a  <fr:link
href="erct-000U.xml"
type="local"
addr="erct-000U">biinverse</fr:link>.</fr:p></fr:mainmatter></fr:tree></fr:mainmatter></fr:tree><fr:tree
xmlns:fr="http://www.jonmsterling.com/jms-005P.xml"
