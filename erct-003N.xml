root="false"><fr:frontmatter><fr:anchor>8627</fr:anchor><fr:addr>erct-003O</fr:addr><fr:route>erct-003O.xml</fr:route><fr:title>Naturality lemmas</fr:title><fr:date><fr:year>2023</fr:year><fr:month>12</fr:month><fr:day>19</fr:day></fr:date><fr:authors><fr:author><fr:link
href="jonmsterling.xml"
type="local"
addr="jonmsterling">Jon Sterling</fr:link></fr:author></fr:authors><fr:parent>erct-000Z</fr:parent></fr:frontmatter><fr:mainmatter><fr:tree
xmlns:fr="http://www.jonmsterling.com/jms-005P.xml"
toc="true"
