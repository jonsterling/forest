            <fr:addr type="user">jms-004M</fr:addr>
            <fr:route>jms-004M.xml</fr:route>
            <fr:title text="Upshift structure">Upshift structure</fr:title>
            <fr:taxon>Definition</fr:taxon>
          </fr:frontmatter>
          <fr:mainmatter>
            <fr:p>Let <fr:tex display="inline"><![CDATA[\mathcal {D}]]></fr:tex> be a <fr:link href="jms-0048.xml" title="Deductive system" addr="jms-0048" type="local">deductive system</fr:link> and let <fr:tex display="inline"><![CDATA[A]]></fr:tex> be an object of <fr:tex display="inline"><![CDATA[\mathcal {D}]]></fr:tex>. An <fr:em>upshift structure</fr:em> for <fr:tex display="inline"><![CDATA[A]]></fr:tex> is defined to be a
  <fr:link href="jms-004B.xml" title="Positive and negative objects" addr="jms-004B" type="local">negative</fr:link> object <fr:tex display="inline"><![CDATA[\mathord {\Uparrow } A]]></fr:tex> and a <fr:link href="jms-004A.xml" title="Linear and thunkable maps" addr="jms-004A" type="local">linear</fr:link> map <fr:tex display="inline"><![CDATA[\mathsf {force}_{A} : \mathord {\Uparrow } A\vdash  A]]></fr:tex> for which there exists a <fr:link href="jms-004N.xml" title="Linear and thunkable inverses" addr="jms-004N" type="local">necessarily unique and thunkable</fr:link> inverse <fr:tex display="inline"><![CDATA[\mathsf {delay}_{A} : A\vdash  \mathord {\Uparrow } A]]></fr:tex>.</fr:p>
          </fr:mainmatter>
