type="user">jms-00L0</fr:addr><fr:route>jms-00L0.xml</fr:route><fr:title
text="Isomorphic sets">Isomorphic sets</fr:title><fr:taxon>Definition</fr:taxon><fr:date><fr:year>2024</fr:year><fr:month>1</fr:month><fr:day>23</fr:day></fr:date><fr:authors><fr:author><fr:link
type="local"
