text="Finite and infinite sets">Finite and infinite sets</fr:title><fr:date><fr:year>2024</fr:year><fr:month>1</fr:month><fr:day>28</fr:day></fr:date><fr:authors><fr:author><fr:link
type="local"
href="jonmsterling.xml"
