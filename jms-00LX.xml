style="white-space: nowrap"><fr:tex
display="inline"><![CDATA[n]]></fr:tex>-element</html:span> set <fr:tex
display="inline"><![CDATA[{\mathopen {}\left \{i\in \mathbb {N}\,\middle \vert \,0\leq  i < n\right \}\mathclose {}}]]></fr:tex>.)</fr:p></fr:mainmatter><fr:backmatter><fr:tree
