              </fr:frontmatter>
              <fr:mainmatter><fr:p>If <fr:tex display="inline"><![CDATA[\mathcal {U}\in \mathcal {V}]]></fr:tex> is an impredicative pair of universes, then <fr:tex display="inline"><![CDATA[\mathcal {U}]]></fr:tex> is reflective in <fr:tex display="inline"><![CDATA[\mathcal {V}]]></fr:tex>.</fr:p>
 
   
   <fr:tree show-metadata="false" toc="false"><fr:frontmatter><fr:authors><fr:author><fr:link href="jonmsterling.xml" title="Jon Sterling" addr="jonmsterling" type="local">Jon Sterling</fr:link></fr:author></fr:authors><fr:date><fr:year>2023</fr:year><fr:month>3</fr:month><fr:day>22</fr:day></fr:date><fr:anchor>11040</fr:anchor><fr:addr type="machine">unstable/2472</fr:addr><fr:route>unstable-2472.xml</fr:route><fr:title text="" /><fr:taxon>Proof</fr:taxon></fr:frontmatter><fr:mainmatter>
