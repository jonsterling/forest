            <fr:title text="Countable set">Countable set</fr:title>
            <fr:taxon>Definition</fr:taxon>
          </fr:frontmatter>
          <fr:mainmatter>
            <fr:p>A <fr:em><fr:strong>countable set</fr:strong></fr:em> is one that is either empty or <fr:link href="jms-00ME.xml" title="Enumerable set" addr="jms-00ME" type="local">enumerable</fr:link>.</fr:p>
          </fr:mainmatter>
        </fr:tree>
