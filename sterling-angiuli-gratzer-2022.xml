<tree expanded="true" show-heading="true" show-metadata="true" toc="false" root="false"><frontmatter> <anchor>19605</anchor> <rss>sterling-angiuli-gratzer-2022.rss.xml</rss> <taxon>Reference</taxon> <addr>sterling-angiuli-gratzer-2022</addr>  <route>sterling-angiuli-gratzer-2022.xml</route> <date><year>2022</year> <month>2</month> <day>9</day></date> <authors><author><link href="jonmsterling.xml" type="local">Jon Sterling</link></author><author><link href="carloangiuli.xml" type="local">Carlo Angiuli</link></author><author><link href="danielgratzer.xml" type="local">Daniel Gratzer</link></author> </authors> <title>A cubical language for Bishop sets</title> <meta name="bibtex">@article{sterling-angiuli-gratzer-2022,
