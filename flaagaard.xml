root="false"><fr:frontmatter><fr:anchor>17754</fr:anchor><fr:taxon>Reference</fr:taxon><fr:addr>aagaard-sterling-birkedal-2023</fr:addr><fr:route>aagaard-sterling-birkedal-2023.xml</fr:route><fr:title>A denotationally-based program logic for higher-order store</fr:title><fr:date><fr:year>2023</fr:year><fr:month>11</fr:month><fr:day>23</fr:day></fr:date><fr:authors><fr:author><fr:link
href="flaagaard.xml"
