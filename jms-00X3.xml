title="Forester 4.2">Forester 4.2</fr:link> › new query language</fr:link> › unions and intersections of families of relational queries</fr:link> › querying the bibliography of a given tree</fr:title><fr:taxon>Example</fr:taxon><fr:date><fr:year>2024</fr:year><fr:month>6</fr:month><fr:day>20</fr:day></fr:date><fr:authors><fr:author><fr:link
type="local"
