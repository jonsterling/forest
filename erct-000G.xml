name="source">
  
  
  <fr:link
type="external"
href="https://git.sr.ht/~jonsterling/agda-erct/tree/main/item/agda/erct-000J.agda">erct-000J.agda</fr:link>
</fr:meta></fr:frontmatter><fr:mainmatter><fr:p>A <fr:link
type="local"
href="erct-000I.xml"
addr="erct-000I"
title="Functor between precategories">functor</fr:link> <fr:tex
display="inline"><![CDATA[F\colon  C \to  D]]></fr:tex> is called an <fr:em><fr:strong>isomorphism</fr:strong></fr:em>, written <fr:tex
display="inline"><![CDATA[f\colon  C\cong  D]]></fr:tex>, when <fr:tex
display="inline"><![CDATA[F]]></fr:tex> is <fr:link
type="local"
href="erct-000K.xml"
addr="erct-000K"
title="Full and faithful functor">fully faithful</fr:link> and its action on objects is an equivalence of types.</fr:p><fr:p>Being an isomorphism is a <fr:link
type="local"
href="erct-001I.xml"
addr="erct-001I"
title="Proposition">proposition</fr:link>.</fr:p></fr:mainmatter><fr:backmatter /></fr:tree><fr:tree
