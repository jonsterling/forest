          <fr:mainmatter><fr:p>A <fr:link href="jms-016M.xml" title="Formal language" addr="jms-016M" type="local">formal language</fr:link> is <fr:link href="jms-017Y.xml" title="Regular language" addr="jms-017Y" type="local">regular</fr:link> if and only if it is <fr:link href="jms-0185.xml" title="Automatical language" addr="jms-0185" type="local">automatical</fr:link>.</fr:p>
 
   
   <fr:tree show-metadata="false" toc="false"><fr:frontmatter><fr:authors><fr:author><fr:link href="jonmsterling.xml" title="Jon Sterling" addr="jonmsterling" type="local">Jon Sterling</fr:link></fr:author></fr:authors><fr:date><fr:year>2025</fr:year><fr:month>2</fr:month><fr:day>16</fr:day></fr:date><fr:anchor>7341</fr:anchor><fr:addr type="machine">unstable/6110</fr:addr><fr:route>unstable-6110.xml</fr:route><fr:title text="" /><fr:taxon>Proof</fr:taxon></fr:frontmatter><fr:mainmatter>
