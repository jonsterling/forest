</fr:meta>
          </fr:frontmatter>
          <fr:mainmatter><fr:p>If a type <fr:tex display="inline"><![CDATA[A]]></fr:tex> is <fr:link href="foreign-erct-erct-001H.xml" title="Contractible type" addr="//erct/erct-001H" type="local">contractible</fr:link>, then it is a <fr:link href="foreign-erct-erct-001I.xml" title="Proposition" addr="//erct/erct-001I" type="local">proposition</fr:link>.</fr:p>
 
   
   <fr:tree show-metadata="false" toc="false"><fr:frontmatter><fr:authors><fr:author><fr:link href="foreign-erct-jonmsterling.xml" title="Jon Sterling" addr="//erct/jonmsterling" type="local">Jon Sterling</fr:link></fr:author></fr:authors><fr:date><fr:year>2023</fr:year><fr:month>12</fr:month><fr:day>20</fr:day></fr:date><fr:anchor>1736</fr:anchor><fr:addr type="machine">//erct/unstable/440</fr:addr><fr:route>foreign-erct-unstable-440.xml</fr:route><fr:title text="" /><fr:taxon>Proof</fr:taxon></fr:frontmatter><fr:mainmatter>
  <fr:p>As <fr:tex display="inline"><![CDATA[A]]></fr:tex> is <fr:link href="foreign-erct-erct-001H.xml" title="Contractible type" addr="//erct/erct-001H" type="local">contractible</fr:link> with some centre <fr:tex display="inline"><![CDATA[a:A]]></fr:tex>, we have for any <fr:tex display="inline"><![CDATA[x,y:A]]></fr:tex> identifications <fr:tex display="inline"><![CDATA[\chi _x \colon  a = x]]></fr:tex> and <fr:tex display="inline"><![CDATA[\chi _y\colon  a = y]]></fr:tex>. Therefore, we identify <fr:tex display="inline"><![CDATA[x]]></fr:tex> with <fr:tex display="inline"><![CDATA[y]]></fr:tex> using <fr:tex display="inline"><![CDATA[\chi _x^{-1} \cdot  \chi _y]]></fr:tex>.</fr:p>
</fr:mainmatter></fr:tree>
 
