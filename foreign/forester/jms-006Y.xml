  <html:li><fr:link href="https://www.jonmsterling.com/foreign/forester/30FM.xml" title="Forester › blog" addr="forest://forester/30FM" type="local">Forester blog</fr:link></html:li>
  <html:li><fr:link href="https://www.jonmsterling.com/foreign/forester/5CDY.xml" title="presentations" addr="forest://forester/5CDY" type="local">Presentations</fr:link></html:li>
  <html:li><fr:link href="https://www.jonmsterling.com/foreign/forester/jms-005P.xml" title="Forester › release notes" addr="forest://forester/jms-005P" type="local">Release notes</fr:link></html:li></html:ul>
