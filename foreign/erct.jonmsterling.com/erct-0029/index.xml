          <fr:mainmatter><html:p>That a given map <fr:tex display="inline"><![CDATA[f\colon  E\to  B]]></fr:tex> is <fr:link href="/foreign/erct.jonmsterling.com/erct-0029/" title="Surjection" uri="https://erct.jonmsterling.com/erct-0029/" display-uri="https://erct.jonmsterling.com/erct-0029" type="local">surjective</fr:link> is a <fr:link href="/foreign/erct.jonmsterling.com/erct-001I/" title="Proposition" uri="https://erct.jonmsterling.com/erct-001I/" display-uri="https://erct.jonmsterling.com/erct-001I" type="local">proposition</fr:link>.</html:p>
 
   
   <fr:tree show-metadata="false" toc="false"><fr:frontmatter><fr:authors><fr:author><fr:link href="/foreign/erct.jonmsterling.com/jonmsterling/" title="Jon Sterling" uri="https://erct.jonmsterling.com/jonmsterling/" display-uri="https://erct.jonmsterling.com/jonmsterling" type="local">Jon Sterling</fr:link></fr:author></fr:authors><fr:date><fr:year>2023</fr:year><fr:month>12</fr:month><fr:day>27</fr:day></fr:date><fr:taxon>Proof</fr:taxon></fr:frontmatter><fr:mainmatter>
