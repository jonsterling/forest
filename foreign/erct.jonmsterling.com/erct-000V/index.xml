   <fr:tree show-metadata="false" toc="false"><fr:frontmatter><fr:authors><fr:author><fr:link href="/foreign/erct.jonmsterling.com/jonmsterling/" title="Jon Sterling" uri="https://erct.jonmsterling.com/jonmsterling/" display-uri="https://erct.jonmsterling.com/jonmsterling/" type="local">Jon Sterling</fr:link></fr:author></fr:authors><fr:date><fr:year>2024</fr:year><fr:month>2</fr:month><fr:day>10</fr:day></fr:date><fr:taxon>Proof</fr:taxon></fr:frontmatter><fr:mainmatter>
 <html:p>By <fr:link href="/foreign/erct.jonmsterling.com/erct-003G/" title="Being bijective is a proposition" uri="https://erct.jonmsterling.com/erct-003G/" display-uri="https://erct.jonmsterling.com/erct-003G/" type="local">Corollary <fr:contextual-number uri="https://erct.jonmsterling.com/erct-003G/" display-uri="https://erct.jonmsterling.com/erct-003G/" /></fr:link> and <fr:link href="/foreign/erct.jonmsterling.com/erct-002S/" title="Being biinvertible is a proposition" uri="https://erct.jonmsterling.com/erct-002S/" display-uri="https://erct.jonmsterling.com/erct-002S/" type="local">Corollary <fr:contextual-number uri="https://erct.jonmsterling.com/erct-002S/" display-uri="https://erct.jonmsterling.com/erct-002S/" /></fr:link> via <fr:link href="/foreign/erct.jonmsterling.com/erct-003D/" title="Path object comprehension" uri="https://erct.jonmsterling.com/erct-003D/" display-uri="https://erct.jonmsterling.com/erct-003D/" type="local">Lemma <fr:contextual-number uri="https://erct.jonmsterling.com/erct-003D/" display-uri="https://erct.jonmsterling.com/erct-003D/" /></fr:link>.</html:p>
</fr:mainmatter></fr:tree>
 
</fr:mainmatter>
        </fr:tree>
        <fr:tree show-metadata="true" expanded="false" toc="false" numbered="false">
          <fr:frontmatter>
