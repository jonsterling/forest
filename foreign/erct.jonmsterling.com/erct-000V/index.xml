      <fr:mainmatter>
        <fr:tree show-metadata="true" expanded="false" toc="false" numbered="false">
          <fr:frontmatter>
            <fr:authors>
              <fr:author>
                <fr:link href="/foreign/erct.jonmsterling.com/jonmsterling/" title="Jon Sterling" uri="https://erct.jonmsterling.com/jonmsterling/" display-uri="https://erct.jonmsterling.com/jonmsterling/" type="local">Jon Sterling</fr:link>
              </fr:author>
            </fr:authors>
            <fr:date>
              <fr:year>2023</fr:year>
              <fr:month>12</fr:month>
              <fr:day>19</fr:day>
            </fr:date>
            <fr:uri>https://erct.jonmsterling.com/erct-000U/</fr:uri>
            <fr:display-uri>https://erct.jonmsterling.com/erct-000U/</fr:display-uri>
            <fr:route>/foreign/erct.jonmsterling.com/erct-000U/</fr:route>
            <fr:title text="Biinverse">Biinverse</fr:title>
            <fr:taxon>Definition</fr:taxon>
            <fr:meta name="source">
  
  
  <fr:link href="https://git.sr.ht/~jonsterling/agda-erct/tree/main/item/agda/erct-000U.agda" type="external">erct-000U.agda</fr:link>
</fr:meta>
          </fr:frontmatter>
          <fr:mainmatter>
            <html:p>A <html:em><html:strong>biinverse</html:strong></html:em> to a function <fr:tex display="inline"><![CDATA[f\colon  A \to  B]]></fr:tex> is defined to be a pair of a <fr:link href="/foreign/erct.jonmsterling.com/erct-000Y/" title="Section-retraction pair" uri="https://erct.jonmsterling.com/erct-000Y/" display-uri="https://erct.jonmsterling.com/erct-000Y/" type="local">section</fr:link> and a <fr:link href="/foreign/erct.jonmsterling.com/erct-000Y/" title="Section-retraction pair" uri="https://erct.jonmsterling.com/erct-000Y/" display-uri="https://erct.jonmsterling.com/erct-000Y/" type="local">retraction</fr:link> to <fr:tex display="inline"><![CDATA[f]]></fr:tex>. We will refer to a function <fr:tex display="inline"><![CDATA[f\colon  A\to  B]]></fr:tex> equipped with a biinverse as a <html:em><html:strong>biinvertible function</html:strong></html:em>.</html:p>
          </fr:mainmatter>
        </fr:tree>
      </fr:mainmatter>
    </fr:tree>
