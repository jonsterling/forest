                  <fr:year>2023</fr:year>
                  <fr:month>12</fr:month>
                  <fr:day>3</fr:day>
                </fr:date>
                <fr:uri>https://erct.jonmsterling.com/erct-000H/</fr:uri>
                <fr:display-uri>https://erct.jonmsterling.com/erct-000H</fr:display-uri>
                <fr:route>/foreign/erct.jonmsterling.com/erct-000H/</fr:route>
                <fr:title text="Category">Category</fr:title>
                <fr:taxon>Definition</fr:taxon>
