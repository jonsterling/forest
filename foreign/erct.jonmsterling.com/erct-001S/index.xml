            <fr:title text="Proposition">Proposition</fr:title>
            <fr:taxon>Definition</fr:taxon>
            <fr:meta name="source">
  
  
  <fr:link href="https://git.sr.ht/~jonsterling/agda-erct/tree/main/item/agda/erct-001I.agda" type="external">erct-001I.agda</fr:link>
</fr:meta>
          </fr:frontmatter>
          <fr:mainmatter>
            <html:p>A type <fr:tex display="inline"><![CDATA[A]]></fr:tex> is said to be a <html:em><html:strong>proposition</html:strong></html:em> when every <fr:tex display="inline"><![CDATA[x:A]]></fr:tex>, the type <fr:tex display="inline"><![CDATA[A]]></fr:tex> is <fr:link href="/foreign/erct.jonmsterling.com/erct-001H/" title="Contractible type" uri="https://erct.jonmsterling.com/erct-001H/" display-uri="https://erct.jonmsterling.com/erct-001H/" type="local">contractible with centre</fr:link> <fr:tex display="inline"><![CDATA[x]]></fr:tex>, i.e. all elements of <fr:tex display="inline"><![CDATA[A]]></fr:tex> are identified.</html:p>
          </fr:mainmatter>
        </fr:tree>
        <fr:tree show-metadata="true" expanded="false" toc="false" numbered="false">
          <fr:frontmatter>
            <fr:authors>
              <fr:author>
                <fr:link href="/foreign/erct.jonmsterling.com/jonmsterling/" title="Jon Sterling" uri="https://erct.jonmsterling.com/jonmsterling/" display-uri="https://erct.jonmsterling.com/jonmsterling/" type="local">Jon Sterling</fr:link>
              </fr:author>
            </fr:authors>
            <fr:date>
              <fr:year>2023</fr:year>
              <fr:month>12</fr:month>
              <fr:day>19</fr:day>
            </fr:date>
