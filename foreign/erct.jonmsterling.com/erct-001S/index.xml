</fr:meta>
          </fr:frontmatter>
          <fr:mainmatter><html:p>If <fr:tex display="inline"><![CDATA[B]]></fr:tex> is a <fr:link href="/foreign/erct.jonmsterling.com/erct-0025/" title="Retract" uri="https://erct.jonmsterling.com/erct-0025/" display-uri="https://erct.jonmsterling.com/erct-0025/" type="local">retract</fr:link> of <fr:tex display="inline"><![CDATA[A]]></fr:tex> and <fr:tex display="inline"><![CDATA[A]]></fr:tex> is a <fr:link href="/foreign/erct.jonmsterling.com/erct-001I/" title="Proposition" uri="https://erct.jonmsterling.com/erct-001I/" display-uri="https://erct.jonmsterling.com/erct-001I/" type="local">proposition</fr:link>, then <fr:tex display="inline"><![CDATA[B]]></fr:tex> is a <fr:link href="/foreign/erct.jonmsterling.com/erct-001I/" title="Proposition" uri="https://erct.jonmsterling.com/erct-001I/" display-uri="https://erct.jonmsterling.com/erct-001I/" type="local">proposition</fr:link>.</html:p>
 
   
   <fr:tree show-metadata="false" toc="false"><fr:frontmatter><fr:authors><fr:author><fr:link href="/foreign/erct.jonmsterling.com/jonmsterling/" title="Jon Sterling" uri="https://erct.jonmsterling.com/jonmsterling/" display-uri="https://erct.jonmsterling.com/jonmsterling/" type="local">Jon Sterling</fr:link></fr:author></fr:authors><fr:date><fr:year>2023</fr:year><fr:month>12</fr:month><fr:day>27</fr:day></fr:date><fr:taxon>Proof</fr:taxon></fr:frontmatter><fr:mainmatter>
