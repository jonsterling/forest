            <fr:title text="the truncation hierarchy › propositional truncation and existence"><fr:link href="https://www.jonmsterling.com/foreign/erct/erct-001E.xml" title="the truncation hierarchy" addr="forest://erct/erct-001E" type="local">the truncation hierarchy</fr:link> › propositional truncation and existence</fr:title>
          </fr:frontmatter>
          <fr:mainmatter>
            <fr:tree show-metadata="false">
              <fr:frontmatter>
                <fr:authors>
