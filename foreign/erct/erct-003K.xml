</fr:meta>
          </fr:frontmatter>
          <fr:mainmatter><html:p>That a given function <fr:tex display="inline"><![CDATA[f\colon  A \to  B]]></fr:tex> is an <fr:link href="https://www.jonmsterling.com/foreign/erct/erct-003K.xml" title="embedding" addr="forest://erct/erct-003K" type="local">embedding</fr:link> is a <fr:link href="https://www.jonmsterling.com/foreign/erct/erct-001I.xml" title="proposition" addr="forest://erct/erct-001I" type="local">proposition</fr:link>.</html:p>
 
   
   <fr:tree show-metadata="false" toc="false"><fr:frontmatter><fr:authors><fr:author><fr:link href="https://www.jonmsterling.com/foreign/erct/jonmsterling.xml" title="Jon Sterling" addr="forest://erct/jonmsterling" type="local">Jon Sterling</fr:link></fr:author></fr:authors><fr:date><fr:year>2024</fr:year><fr:month>2</fr:month><fr:day>18</fr:day></fr:date><fr:addr>forest://erct/erct-0047/0</fr:addr><fr:route>https://www.jonmsterling.com/foreign/erct/erct-0047/0.xml</fr:route><fr:title text="being an embedding is a proposition › forest://erct/erct-0047/0"><fr:link href="https://www.jonmsterling.com/foreign/erct/erct-0047.xml" title="being an embedding is a proposition" addr="forest://erct/erct-0047" type="local">being an <fr:link href="https://www.jonmsterling.com/foreign/erct/erct-003K.xml" title="embedding" addr="forest://erct/erct-003K" type="local">embedding</fr:link> is a <fr:link href="https://www.jonmsterling.com/foreign/erct/erct-001I.xml" title="proposition" addr="forest://erct/erct-001I" type="local">proposition</fr:link></fr:link> › forest://erct/erct-0047/0</fr:title><fr:taxon>Proof</fr:taxon></fr:frontmatter><fr:mainmatter>
