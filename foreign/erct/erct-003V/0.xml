    <fr:title text="dependent sum of contractible types › forest://erct/erct-003V/0"><fr:link href="https://www.jonmsterling.com/foreign/erct/erct-003V.xml" title="dependent sum of contractible types" addr="forest://erct/erct-003V" type="local">dependent sum of <fr:link href="https://www.jonmsterling.com/foreign/erct/erct-001H.xml" title="contractible type" addr="forest://erct/erct-001H" type="local">contractible types</fr:link></fr:link> › forest://erct/erct-003V/0</fr:title>
