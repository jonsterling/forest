xmlns:html="http://www.w3.org/1999/xhtml"><fr:tex
display="inline"><![CDATA[n]]></fr:tex>-truncated</html:span> type</fr:title><fr:taxon>Definition</fr:taxon><fr:meta
name="source">
  
  
  <fr:link
