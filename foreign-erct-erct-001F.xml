            <fr:route>foreign-erct-erct-002T-0.xml</fr:route>
            <fr:title text="Truncation is upward closed › "><fr:link href="foreign-erct-erct-002T.xml" title="Truncation is upward closed" addr="forest://erct/erct-002T" type="local"><fr:link href="foreign-erct-erct-001G.xml" title="n-truncated type" addr="forest://erct/erct-001G" type="local">Truncation</fr:link> is upward closed</fr:link> › </fr:title>
            <fr:taxon>Proof</fr:taxon>
          </fr:frontmatter>
          <fr:mainmatter>
 <html:p>By induction on the <fr:link href="foreign-erct-erct-001F.xml" title="Indexing of truncation levels" addr="forest://erct/erct-001F" type="local">truncation level</fr:link> <fr:tex display="inline"><![CDATA[n]]></fr:tex>, with two base cases given by <fr:link href="foreign-erct-erct-001K.xml" title="Contractible types are propositions" addr="forest://erct/erct-001K" type="local">Lemma <fr:contextual-number addr="forest://erct/erct-001K" /></fr:link> and <fr:link href="foreign-erct-erct-001L.xml" title="Propositions are sets" addr="forest://erct/erct-001L" type="local">Lemma <fr:contextual-number addr="forest://erct/erct-001L" /></fr:link>.</html:p>
</fr:mainmatter>
        </fr:tree>
        <fr:tree show-metadata="true" expanded="false" toc="false" numbered="false">
          <fr:frontmatter>
            <fr:authors>
              <fr:author>
