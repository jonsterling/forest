          <fr:mainmatter><fr:p>Any <fr:link href="foreign-erct-erct-003F.xml" title="Bijection" addr="//erct/erct-003F" type="local">bijection</fr:link> <fr:tex display="inline"><![CDATA[f\colon  A\to  B]]></fr:tex> is <fr:link href="foreign-erct-erct-000U.xml" title="Biinverse" addr="//erct/erct-000U" type="local">biinvertible</fr:link>.</fr:p>
 
   
   <fr:tree show-metadata="false" toc="false"><fr:frontmatter><fr:authors><fr:author><fr:link href="foreign-erct-jonmsterling.xml" title="Jon Sterling" addr="//erct/jonmsterling" type="local">Jon Sterling</fr:link></fr:author></fr:authors><fr:date><fr:year>2023</fr:year><fr:month>12</fr:month><fr:day>31</fr:day></fr:date><fr:anchor>3474</fr:anchor><fr:addr type="machine">//erct/unstable/474</fr:addr><fr:route>foreign-erct-unstable-474.xml</fr:route><fr:title text="" /><fr:taxon>Proof</fr:taxon></fr:frontmatter><fr:mainmatter>
 <fr:p>By <fr:link href="foreign-erct-erct-002Y.xml" title="Bijections are contractible" addr="//erct/erct-002Y" type="local">Lemma <fr:contextual-number addr="//erct/erct-002Y" /></fr:link>, <fr:link href="foreign-erct-erct-003F.xml" title="Bijection" addr="//erct/erct-003F" type="local">bijections</fr:link> are <fr:link href="foreign-erct-erct-001T.xml" title="n-truncated map" addr="//erct/erct-001T" type="local">contractible</fr:link>; by <fr:link href="foreign-erct-erct-002H.xml" title="Contractible maps are biinvertible" addr="//erct/erct-002H" type="local">Corollary <fr:contextual-number addr="//erct/erct-002H" /></fr:link>, <fr:link href="foreign-erct-erct-003F.xml" title="Bijection" addr="//erct/erct-003F" type="local">bijections</fr:link> are <fr:link href="foreign-erct-erct-001T.xml" title="n-truncated map" addr="//erct/erct-001T" type="local">contractible</fr:link>.</fr:p>
</fr:mainmatter></fr:tree>
 
</fr:mainmatter>
