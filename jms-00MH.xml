type="local"
href="jms-00MH.xml"
addr="jms-00MH"
title="Countable set">countability</fr:link></fr:title><fr:taxon>Lemma</fr:taxon><fr:date><fr:year>2024</fr:year><fr:month>1</fr:month><fr:day>29</fr:day></fr:date><fr:authors><fr:author><fr:link
type="local"
href="jonmsterling.xml"
addr="jonmsterling"
title="Jon Sterling">Jon Sterling</fr:link></fr:author></fr:authors></fr:frontmatter><fr:mainmatter><fr:p>A set <fr:tex
display="inline"><![CDATA[A]]></fr:tex> is <fr:link
type="local"
href="jms-00MH.xml"
addr="jms-00MH"
title="Countable set">countable</fr:link> if and only if the disjoint union <fr:tex
display="inline"><![CDATA[A+{\mathopen {}\left  [1\right  ]\mathclose {}}]]></fr:tex> is <fr:link
type="local"
href="jms-00ME.xml"
addr="jms-00ME"
title="Enumerable set">enumerable</fr:link>.</fr:p>
 
   
   <fr:tree
toc="false"
numbered="true"
show-heading="true"
