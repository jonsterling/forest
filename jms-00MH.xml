expanded="true"
root="false"
xmlns:fr="http://www.jonmsterling.com/jms-005P.xml"><fr:frontmatter><fr:anchor>3734</fr:anchor><fr:addr>#374</fr:addr><fr:route>unstable-374.xml</fr:route><fr:taxon>Proof</fr:taxon><fr:date><fr:year>2024</fr:year><fr:month>1</fr:month><fr:day>29</fr:day></fr:date><fr:authors><fr:author><fr:link
type="local"
href="jonmsterling.xml"
addr="jonmsterling"
title="Jon Sterling">Jon Sterling</fr:link></fr:author></fr:authors><fr:parent>jms-00MK</fr:parent></fr:frontmatter><fr:mainmatter>
 <fr:p>We will use the same method as in our proof of <fr:ref
addr="jms-00MI"
taxon="Lemma" />.</fr:p>
 <fr:p>Let <fr:tex
display="inline"><![CDATA[S\subseteq  A]]></fr:tex> be a non-empty subset of an <fr:link
type="local"
href="jms-00ME.xml"
addr="jms-00ME"
title="Enumerable set">enumerable</fr:link> set <fr:tex
display="inline"><![CDATA[A]]></fr:tex>, so that we have some <fr:tex
display="inline"><![CDATA[s\in  S]]></fr:tex> and a <fr:link
type="local"
href="jms-00M8.xml"
addr="jms-00M8"
title="Surjection">surjection</fr:link> <fr:tex
display="inline"><![CDATA[e\colon \mathbb {N}\twoheadrightarrow  A]]></fr:tex>. We define <fr:tex
display="inline"><![CDATA[e'\colon  \mathbb {N}\twoheadrightarrow {S}]]></fr:tex> to send <fr:tex
display="inline"><![CDATA[i\in \mathbb {N}]]></fr:tex> to <fr:tex
display="inline"><![CDATA[e{\mathopen {}\left (i\right )\mathclose {}}]]></fr:tex> if <fr:tex
display="inline"><![CDATA[e{\mathopen {}\left (i\right )\mathclose {}}\in  S]]></fr:tex> and to <fr:tex
display="inline"><![CDATA[s]]></fr:tex> otherwise.</fr:p>
</fr:mainmatter><fr:backmatter /></fr:tree>
 
</fr:mainmatter><fr:backmatter /></fr:tree><fr:tree
