type="local"
href="jms-00ME.xml"
addr="jms-00ME"
title="Enumerable set">enumerable</fr:link> sets are <fr:link
type="local"
href="jms-00ME.xml"
addr="jms-00ME"
title="Enumerable set">enumerable</fr:link></fr:title><fr:taxon>Lemma</fr:taxon><fr:date><fr:year>2024</fr:year><fr:month>1</fr:month><fr:day>29</fr:day></fr:date><fr:authors><fr:author><fr:link
type="local"
href="jonmsterling.xml"
addr="jonmsterling"
title="Jon Sterling">Jon Sterling</fr:link></fr:author><fr:contributor><fr:link
type="local"
href="marcelofiore.xml"
addr="marcelofiore"
title="Marcelo Fiore">Marcelo Fiore</fr:link></fr:contributor></fr:authors></fr:frontmatter><fr:mainmatter><fr:p>Any non-empty subset of an <fr:link
type="local"
href="jms-00ME.xml"
addr="jms-00ME"
title="Enumerable set">enumerable</fr:link> set is <fr:link
type="local"
href="jms-00ME.xml"
addr="jms-00ME"
title="Enumerable set">enumerable</fr:link>.</fr:p>
 
   
   <fr:tree
toc="false"
numbered="true"
show-heading="true"
