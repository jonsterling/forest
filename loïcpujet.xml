xmlns:fr="http://www.jonmsterling.com/jms-005P.xml"><fr:frontmatter><fr:anchor>22505</fr:anchor><fr:addr>sterling-2022-pujet-workshop</fr:addr><fr:route>sterling-2022-pujet-workshop.xml</fr:route><fr:title>Controlling unfolding in type theory</fr:title><fr:taxon>Reference</fr:taxon><fr:date><fr:year>2022</fr:year><fr:month>12</fr:month><fr:day>14</fr:day></fr:date><fr:authors><fr:author><fr:link
