addr="jms-00IN"
title="Relational composite">composition</fr:link></fr:title><fr:taxon>Theorem</fr:taxon><fr:date><fr:year>2024</fr:year><fr:month>1</fr:month><fr:day>22</fr:day></fr:date><fr:authors><fr:author><fr:link
