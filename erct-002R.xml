type="local">proposition</fr:link>, which follows via <fr:link
href="erct-001K.xml"
title="Contractible types are propositions"
addr="erct-001K"
type="local">Lemma <fr:contextual-number
addr="erct-001K" /></fr:link> and <fr:link
href="erct-002O.xml"
title="Pushforward along biinvertible maps"
addr="erct-002O"
