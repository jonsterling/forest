root="false"><fr:frontmatter><fr:anchor>10930</fr:anchor><fr:taxon>Definition</fr:taxon><fr:addr>jms-00BN</fr:addr><fr:route>jms-00BN.xml</fr:route><fr:title>Event structure</fr:title><fr:date><fr:year>2023</fr:year><fr:month>10</fr:month><fr:day>26</fr:day></fr:date><fr:authors><fr:author><fr:link
