            <fr:title text="Countable set">Countable set</fr:title>
            <fr:taxon>Definition</fr:taxon>
          </fr:frontmatter>
          <fr:mainmatter>
            <html:p>A <html:em><html:strong>countable set</html:strong></html:em> is one that is either empty or <fr:link href="jms-00ME.xml" title="Enumerable set" addr="jms-00ME" type="local">enumerable</fr:link>.</html:p>
          </fr:mainmatter>
        </fr:tree>
