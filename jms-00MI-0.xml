            </fr:date>
            <fr:addr>jms-00ME</fr:addr>
            <fr:route>jms-00ME.xml</fr:route>
            <fr:title text="Enumerable set">Enumerable set</fr:title>
            <fr:taxon>Definition</fr:taxon>
          </fr:frontmatter>
          <fr:mainmatter>
            <html:p>A set <fr:tex display="inline"><![CDATA[A]]></fr:tex> is said to be <html:em><html:strong>enumerable</html:strong></html:em> whenever there exists a surjection <fr:tex display="inline"><![CDATA[\mathbb {N}\twoheadrightarrow  A]]></fr:tex>, referred to as an <html:em><html:strong>enumeration</html:strong></html:em>.</html:p>
          </fr:mainmatter>
        </fr:tree>
        <fr:tree show-metadata="true" expanded="false" toc="false" numbered="false">
