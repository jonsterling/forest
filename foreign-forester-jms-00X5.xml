      <fr:mainmatter>
        <fr:tree show-metadata="true" expanded="false" toc="false" numbered="false">
          <fr:frontmatter>
            <fr:authors>
              <fr:author>
                <fr:link href="foreign-forester-jonmsterling.xml" title="Jon Sterling" addr="//forester/jonmsterling" type="local">Jon Sterling</fr:link>
              </fr:author>
            </fr:authors>
