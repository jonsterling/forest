        <fr:tree show-metadata="true" expanded="false" toc="false" numbered="false">
          <fr:frontmatter>
            <fr:authors>
              <fr:author>
                <fr:link href="tomdejong.xml" title="Tom de Jong" addr="tomdejong" type="local">Tom de Jong</fr:link>
              </fr:author>
              <fr:author>
                <fr:link href="martinescardo.xml" title="Martín Hötzel Escardó" addr="martinescardo" type="local">Martín Hötzel Escardó</fr:link>
              </fr:author>
              <fr:author>
                <fr:link href="jonmsterling.xml" title="Jon Sterling" addr="jonmsterling" type="local">Jon Sterling</fr:link>
