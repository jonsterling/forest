            <fr:title text="the idempotent determined by a section-retraction pair">the <fr:link href="https://www.jonmsterling.com/jms-00LA.xml" title="idempotent function" addr="jms-00LA" type="local">idempotent</fr:link> determined by a <fr:link href="https://www.jonmsterling.com/jms-00KS.xml" title="section-retraction pair" addr="jms-00KS" type="local">section-retraction pair</fr:link></fr:title>
            <fr:taxon>Lemma</fr:taxon>
          </fr:frontmatter>
          <fr:mainmatter><html:p>Every <fr:link href="https://www.jonmsterling.com/jms-00KS.xml" title="section-retraction pair" addr="jms-00KS" type="local">section-retraction pair</fr:link> determines an <fr:link href="https://www.jonmsterling.com/jms-00LA.xml" title="idempotent function" addr="jms-00LA" type="local">idempotent</fr:link>. In particular, when <fr:tex display="inline"><![CDATA[s\colon  B\to  A]]></fr:tex> is a <fr:link href="https://www.jonmsterling.com/jms-00KS.xml" title="section-retraction pair" addr="jms-00KS" type="local">section</fr:link> of <fr:tex display="inline"><![CDATA[r\colon  A \to  B]]></fr:tex>, the composite <fr:tex display="inline"><![CDATA[s\circ  r\colon  A\to  A]]></fr:tex> is <fr:link href="https://www.jonmsterling.com/jms-00LA.xml" title="idempotent function" addr="jms-00LA" type="local">idempotent</fr:link>.</html:p>
 
   
   <fr:tree show-metadata="false" toc="false"><fr:frontmatter><fr:authors><fr:author><fr:link href="https://www.jonmsterling.com/jonmsterling.xml" title="Jon Sterling" addr="jonmsterling" type="local">Jon Sterling</fr:link></fr:author></fr:authors><fr:date><fr:year>2024</fr:year><fr:month>1</fr:month><fr:day>25</fr:day></fr:date><fr:addr>jms-00LB/0</fr:addr><fr:route>https://www.jonmsterling.com/jms-00LB/0.xml</fr:route><fr:title text="the idempotent determined by a section-retraction pair › forest://jonmsterling/jms-00LB/0"><fr:link href="https://www.jonmsterling.com/jms-00LB.xml" title="the idempotent determined by a section-retraction pair" addr="jms-00LB" type="local">the <fr:link href="https://www.jonmsterling.com/jms-00LA.xml" title="idempotent function" addr="jms-00LA" type="local">idempotent</fr:link> determined by a <fr:link href="https://www.jonmsterling.com/jms-00KS.xml" title="section-retraction pair" addr="jms-00KS" type="local">section-retraction pair</fr:link></fr:link> › jms-00LB/0</fr:title><fr:taxon>Proof</fr:taxon></fr:frontmatter><fr:mainmatter>
 <html:p>We proceed by calculation:</html:p>
 <fr:tex display="block"><![CDATA[
  \begin {aligned}
    {\mathopen {}\left (s\circ  r\right )\mathclose {}}\circ {\mathopen {}\left (s\circ  r\right )\mathclose {}}
    &=
    s\circ  {\mathopen {}\left (r\circ  s\right )\mathclose {}}\circ  r
    \\
    &=
    s\circ  \mathsf {id}_{B} \circ  r
    \\
    &=
    s\circ  r
  \end {aligned}
 ]]></fr:tex>
</fr:mainmatter></fr:tree>
 
