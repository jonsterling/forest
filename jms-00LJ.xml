xmlns:fr="http://www.jonmsterling.com/jms-005P.xml"><fr:frontmatter><fr:anchor>3714</fr:anchor><fr:addr>jms-00LK</fr:addr><fr:route>jms-00LK.xml</fr:route><fr:title>Invariance under isomorphism</fr:title><fr:taxon>Example</fr:taxon><fr:date><fr:year>2024</fr:year><fr:month>1</fr:month><fr:day>25</fr:day></fr:date><fr:authors><fr:author><fr:link
