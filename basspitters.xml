root="false"><fr:frontmatter><fr:anchor>20216</fr:anchor><fr:taxon>Reference</fr:taxon><fr:addr>bbcgsv-2019</fr:addr><fr:route>bbcgsv-2019.xml</fr:route><fr:title>Guarded cubical type theory</fr:title><fr:date><fr:year>2019</fr:year></fr:date><fr:authors><fr:author><fr:link
