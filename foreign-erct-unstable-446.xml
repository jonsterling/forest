            <fr:title text="Dependent product of propositions">Dependent product of <fr:link href="foreign-erct-erct-001I.xml" title="Proposition" addr="//erct/erct-001I" type="local">propositions</fr:link></fr:title>
            <fr:taxon>Corollary</fr:taxon>
