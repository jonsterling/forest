addr="//erct/erct-001K" /></fr:link> and <fr:link
href="foreign-erct-erct-001L.xml"
title="Propositions are sets"
addr="//erct/erct-001L"
type="local">Lemma <fr:contextual-number
addr="//erct/erct-001L" /></fr:link>.</fr:p>
