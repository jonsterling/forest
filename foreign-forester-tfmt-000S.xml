  <html:tr xmlns:html="http://www.w3.org/1999/xhtml">
    
  <html:th xmlns:html="http://www.w3.org/1999/xhtml">Declaration</html:th>

    
  <html:th xmlns:html="http://www.w3.org/1999/xhtml">Meaning</html:th>

  </html:tr>

  
 <html:tr xmlns:html="http://www.w3.org/1999/xhtml">
