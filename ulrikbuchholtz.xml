    <fr:title text="Ulrik Buchholtz">Ulrik Buchholtz</fr:title>
    <fr:taxon>Person</fr:taxon>
    <fr:meta name="external">https://ulrikbuchholtz.dk/</fr:meta>
    <fr:meta name="position">Assistant Professor</fr:meta>
