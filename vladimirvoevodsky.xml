text="Reflexive graph lenses in univalent foundations">Reflexive graph lenses in univalent foundations</fr:title><fr:taxon>Reference</fr:taxon><fr:date><fr:year>2024</fr:year><fr:month>3</fr:month><fr:day>30</fr:day></fr:date><fr:authors><fr:author><fr:link
type="local"
