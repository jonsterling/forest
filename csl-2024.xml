root="false"><fr:frontmatter><fr:anchor>2044</fr:anchor><fr:taxon>Reference</fr:taxon><fr:addr>moreau-nguyen-2023</fr:addr><fr:route>moreau-nguyen-2023.xml</fr:route><fr:title>Syntactically and semantically regular languages of lambda-terms coincide through logical relations</fr:title><fr:authors><fr:author><fr:link
href="vincentmoreau.xml"
type="local"
addr="vincentmoreau">Vincent Moreau</fr:link></fr:author><fr:author>Lê Thành Dũng Nguyên</fr:author></fr:authors><fr:meta
