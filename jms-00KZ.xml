type="local">Jon Sterling</fr:link></fr:author></fr:authors><fr:date><fr:year>2024</fr:year><fr:month>1</fr:month><fr:day>22</fr:day></fr:date><fr:anchor>7740</fr:anchor><fr:addr
type="machine">unstable/6024</fr:addr><fr:route>unstable-6024.xml</fr:route><fr:title
text="" /><fr:taxon>Proof</fr:taxon></fr:frontmatter><fr:mainmatter>
 <fr:p>We have already seen in <fr:link
href="jms-00K8.xml"
title="Closure of partial functions under identity and composition"
addr="jms-00K8"
type="local">Theorem <fr:contextual-number
addr="jms-00K8" /></fr:link> that <fr:link
href="jms-00K7.xml"
title="Partial function"
addr="jms-00K7"
type="local">partial functions</fr:link> are closed under <fr:link
href="jms-00II.xml"
title="The identity relation"
addr="jms-00II"
type="local">identity</fr:link> and <fr:link
href="jms-00IN.xml"
title="Relational composite"
addr="jms-00IN"
type="local">composition</fr:link>. Therefore, it suffices to argue that the <fr:link
href="jms-00II.xml"
title="The identity relation"
addr="jms-00II"
type="local">identity</fr:link> <fr:link
href="jms-00K7.xml"
title="Partial function"
addr="jms-00K7"
type="local">partial function</fr:link> is total, and that the <fr:link
href="jms-00IN.xml"
title="Relational composite"
addr="jms-00IN"
type="local">composition</fr:link> of two <fr:link
href="jms-00KF.xml"
title="Function"
addr="jms-00KF"
type="local">total</fr:link> <fr:link
href="jms-00K7.xml"
title="Partial function"
addr="jms-00K7"
type="local">partial functions</fr:link> is <fr:link
href="jms-00KF.xml"
title="Function"
addr="jms-00KF"
type="local">total</fr:link>.</fr:p>

 <fr:ol><fr:li>We must show that for all <fr:tex
display="inline"><![CDATA[a\in  A]]></fr:tex>, there exists <fr:tex
display="inline"><![CDATA[a' \in  A]]></fr:tex> such that <fr:tex
display="inline"><![CDATA[a\mathrel {\mathsf {id}_{A}} a']]></fr:tex>; unfolding the definition of the <fr:link
href="jms-00II.xml"
title="The identity relation"
addr="jms-00II"
type="local">identity relation</fr:link> we may choose <fr:tex
display="inline"><![CDATA[a' = a]]></fr:tex>.</fr:li>
  <fr:li>Given <fr:tex
display="inline"><![CDATA[f\colon  A\to  B]]></fr:tex> and <fr:tex
display="inline"><![CDATA[g\colon  A \to  C]]></fr:tex>, we must check that for all <fr:tex
display="inline"><![CDATA[a\in  A]]></fr:tex>, there exists some <fr:tex
display="inline"><![CDATA[c\in  C]]></fr:tex> such that <fr:tex
display="inline"><![CDATA[a\mathrel {{\mathopen {}\left (g\circ  f\right )\mathclose {}}}c]]></fr:tex>. By the definition of <fr:link
href="jms-00IN.xml"
title="Relational composite"
addr="jms-00IN"
type="local">relational composition</fr:link>, we must show that there exists <fr:tex
display="inline"><![CDATA[b\in  B]]></fr:tex> and <fr:tex
display="inline"><![CDATA[c\in  C]]></fr:tex> and such that <fr:tex
display="inline"><![CDATA[a\mathrel {f}b]]></fr:tex> and <fr:tex
display="inline"><![CDATA[b\mathrel {c}]]></fr:tex>. We choose <fr:tex
display="inline"><![CDATA[b = f{\mathopen {}\left (a\right )\mathclose {}}]]></fr:tex> and <fr:tex
display="inline"><![CDATA[c = g{\mathopen {}\left (b\right )\mathclose {}}=g{\mathopen {}\left (f{\mathopen {}\left (a\right )\mathclose {}}\right )\mathclose {}}]]></fr:tex>.</fr:li></fr:ol>
</fr:mainmatter></fr:tree>
 
