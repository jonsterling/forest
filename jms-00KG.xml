xmlns:fr="http://www.jonmsterling.com/jms-005P.xml"><fr:frontmatter><fr:anchor>1600</fr:anchor><fr:addr
type="machine">#400</fr:addr><fr:route>unstable-400.xml</fr:route><fr:taxon>Proof</fr:taxon><fr:date><fr:year>2024</fr:year><fr:month>1</fr:month><fr:day>22</fr:day></fr:date><fr:authors><fr:author><fr:link
