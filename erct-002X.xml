root="false"><fr:frontmatter><fr:anchor>1952</fr:anchor><fr:taxon>Lemma</fr:taxon><fr:addr>erct-0049</fr:addr><fr:route>erct-0049.xml</fr:route><fr:title><fr:link
href="erct-001T.xml"
type="local"
addr="erct-001T">Propositional maps</fr:link> are <fr:link
