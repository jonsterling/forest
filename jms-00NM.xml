text="The principle of well-founded induction">The principle of well-founded induction</fr:title><fr:taxon>Proposition</fr:taxon><fr:date><fr:year>2024</fr:year><fr:month>1</fr:month><fr:day>31</fr:day></fr:date><fr:authors><fr:author><fr:link
type="local"
