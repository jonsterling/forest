    <fr:title text="Naturality of homotopies onto the identity › "><fr:link href="foreign-erct-erct-001W.xml" title="Naturality of homotopies onto the identity" addr="//erct/erct-001W" type="local">Naturality of <fr:link href="foreign-erct-erct-0014.xml" title="Homotopy" addr="//erct/erct-0014" type="local">homotopies</fr:link> onto the identity</fr:link> › </fr:title>
