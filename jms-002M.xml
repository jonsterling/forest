   <fr:tree show-metadata="false" toc="false"><fr:frontmatter><fr:authors><fr:author><fr:link href="https://www.jonmsterling.com/jonmsterling.xml" title="Jon Sterling" addr="jonmsterling" type="local">Jon Sterling</fr:link></fr:author></fr:authors><fr:date><fr:year>2023</fr:year><fr:month>2</fr:month><fr:day>16</fr:day></fr:date><fr:addr>jms-002M/0</fr:addr><fr:route>https://www.jonmsterling.com/jms-002M/0.xml</fr:route><fr:title text="positively generated basis yields positive generation › forest://jonmsterling/jms-002M/0"><fr:link href="https://www.jonmsterling.com/jms-002M.xml" title="positively generated basis yields positive generation" addr="jms-002M" type="local">positively generated basis yields positive generation</fr:link> › jms-002M/0</fr:title><fr:taxon>Proof</fr:taxon></fr:frontmatter><fr:mainmatter>
