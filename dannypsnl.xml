root="false"><fr:frontmatter><fr:anchor>748</fr:anchor><fr:taxon>Feature</fr:taxon><fr:addr>jms-00CX</fr:addr><fr:route>jms-00CX.xml</fr:route><fr:title>Proper diagnostics with source locations</fr:title><fr:date><fr:year>2023</fr:year><fr:month>11</fr:month><fr:day>3</fr:day></fr:date><fr:authors><fr:author><fr:link
href="jonmsterling.xml"
type="local"
addr="jonmsterling">Jon Sterling</fr:link></fr:author></fr:authors><fr:parent>jms-00CW</fr:parent></fr:frontmatter><fr:mainmatter><fr:p><fr:link
href="jms-00CW.xml"
type="local"
addr="jms-00CW">Forester 3.0</fr:link> adds proper diagnostics and error messages, via the excellent <fr:link
href="https://ocaml.org/p/asai/latest"
type="external">asai</fr:link> library maintained by <fr:link
href="favonia.xml"
type="local"
addr="favonia">Favonia</fr:link>. When something goes wrong in your forest, the terminal output should expain what happened while displaying the precise location in your source file.</fr:p></fr:mainmatter></fr:tree><fr:tree
xmlns:fr="http://www.jonmsterling.com/jms-005P.xml"
toc="true"
numbered="true"
