            <fr:title text="Duploid">Duploid</fr:title>
            <fr:taxon>Definition</fr:taxon>
          </fr:frontmatter>
          <fr:mainmatter>
            <fr:p>A <fr:link href="jms-004F.xml" title="Preduploid" addr="jms-004F" type="local">preduploid</fr:link> <fr:tex display="inline"><![CDATA[\mathcal {D}]]></fr:tex> is called a <fr:em>duploid</fr:em> when it satisfies the following properties:</fr:p>
            <fr:ol><fr:li>the preduploid <fr:tex display="inline"><![CDATA[\mathcal {D}]]></fr:tex> is <fr:link href="jms-004T.xml" title="Univalent deductive system" addr="jms-004T" type="local">univalent</fr:link>;</fr:li>
  <fr:li>every <fr:link href="jms-004B.xml" title="Positive and negative objects" addr="jms-004B" type="local">positive</fr:link> object of <fr:tex display="inline"><![CDATA[\mathcal {D}]]></fr:tex> <fr:link href="jms-004X.xml" title="Uniqueness of upshifts" addr="jms-004X" type="local">has an upshift</fr:link>;</fr:li>
  <fr:li>every <fr:link href="jms-004B.xml" title="Positive and negative objects" addr="jms-004B" type="local">negative</fr:link> object of <fr:tex display="inline"><![CDATA[\mathcal {D}]]></fr:tex> <fr:link href="jms-004Z.xml" title="Uniqueness of downshifts" addr="jms-004Z" type="local">has a downshift</fr:link>.</fr:li></fr:ol>
          </fr:mainmatter>
        </fr:tree>
