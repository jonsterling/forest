xmlns:fr="http://www.jonmsterling.com/jms-005P.xml"><fr:frontmatter><fr:anchor>18240</fr:anchor><fr:addr>hottbook</fr:addr><fr:route>hottbook.xml</fr:route><fr:title>Homotopy Type Theory: univalent foundations of mathematics</fr:title><fr:taxon>Reference</fr:taxon><fr:date><fr:year>2013</fr:year></fr:date><fr:authors><fr:author>The Univalent Foundations Program</fr:author></fr:authors><fr:meta
name="external">https://homotopytypetheory.org/book</fr:meta><fr:meta
name="venue"><fr:link
