    <fr:title text="The idempotent determined by a section-retraction pair › "><fr:link href="jms-00LB.xml" title="The idempotent determined by a section-retraction pair" addr="jms-00LB" type="local">The <fr:link href="jms-00LA.xml" title="Idempotent function" addr="jms-00LA" type="local">idempotent</fr:link> determined by a <fr:link href="jms-00KS.xml" title="Section-retraction pair" addr="jms-00KS" type="local">section-retraction pair</fr:link></fr:link> › </fr:title>
    <fr:taxon>Proof</fr:taxon>
