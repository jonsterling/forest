  <fr:mainmatter>
 <fr:p>We proceed by calculation:</fr:p>
 <fr:tex display="block"><![CDATA[
  \begin {aligned}
    {\mathopen {}\left (s\circ  r\right )\mathclose {}}\circ {\mathopen {}\left (s\circ  r\right )\mathclose {}}
    &=
    s\circ  {\mathopen {}\left (r\circ  s\right )\mathclose {}}\circ  r
    \\
    &=
    s\circ  \mathsf {id}_{B} \circ  r
    \\
    &=
    s\circ  r
  \end {aligned}
 ]]></fr:tex>
</fr:mainmatter>
