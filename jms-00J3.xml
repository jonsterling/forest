title="Matrix over a semiring">matrix</fr:link></html:span>:</fr:p><fr:tex
display="block"><![CDATA[  {\mathopen {}\left (N\cdot  M\right )\mathclose {}}_{i\in  {\mathopen {}\left  [l\right  ]\mathclose {}},j\in {\mathopen {}\left  [n\right  ]\mathclose {}}} =  \bigoplus _{k\in  {\mathopen {}\left  [m\right  ]\mathclose {}}} M_{i,k}\cdot  N_{k,j} ]]></fr:tex></fr:mainmatter><fr:backmatter /></fr:tree><fr:tree
