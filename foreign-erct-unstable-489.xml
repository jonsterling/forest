    <fr:title text="Dependent product of n-truncated types › "><fr:link href="foreign-erct-erct-003Z.xml" title="Dependent product of n-truncated types" addr="//erct/erct-003Z" type="local">Dependent product of <fr:link href="foreign-erct-erct-001G.xml" title="n-truncated type" addr="//erct/erct-001G" type="local"><html:span style="white-space: nowrap" xmlns:html="http://www.w3.org/1999/xhtml"><fr:tex display="inline"><![CDATA[n]]></fr:tex>-truncated</html:span></fr:link> types</fr:link> › </fr:title>
    <fr:taxon>Proof</fr:taxon>
