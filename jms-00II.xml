xmlns:fr="http://www.jonmsterling.com/jms-005P.xml"><fr:frontmatter><fr:anchor>6816</fr:anchor><fr:addr>jms-00JD</fr:addr><fr:route>jms-00JD.xml</fr:route><fr:title>Monoid structure of endo-relations</fr:title><fr:taxon>Corollary</fr:taxon><fr:date><fr:year>2024</fr:year><fr:month>1</fr:month><fr:day>18</fr:day></fr:date><fr:authors><fr:author><fr:link
