xmlns:fr="http://www.jonmsterling.com/jms-005P.xml"><fr:frontmatter><fr:anchor>6819</fr:anchor><fr:addr>jms-00IP</fr:addr><fr:route>jms-00IP.xml</fr:route><fr:title>Associativity and unit laws of <fr:link
type="local"
href="jms-00IN.xml"
addr="jms-00IN"
title="Relational composite">relational composition</fr:link></fr:title><fr:taxon>Lemma</fr:taxon><fr:date><fr:year>2024</fr:year><fr:month>1</fr:month><fr:day>17</fr:day></fr:date><fr:authors><fr:author><fr:link
type="local"
