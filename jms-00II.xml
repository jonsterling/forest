text="" /><fr:taxon>Proof</fr:taxon></fr:frontmatter><fr:mainmatter>
 <fr:p>The <fr:link
href="jms-00KI.xml"
title="Closure of functions under identity and composition"
addr="jms-00KI"
type="local">identity function</fr:link> is clearly <fr:link
href="jms-00KI.xml"
title="Closure of functions under identity and composition"
addr="jms-00KI"
type="local">injective</fr:link>, as <fr:tex
display="inline"><![CDATA[a_0=a_1]]></fr:tex> implies <fr:tex
display="inline"><![CDATA[a_0=a_1]]></fr:tex>.</fr:p>

 <fr:p>Let <fr:tex
display="inline"><![CDATA[f\colon  A\rightarrowtail  B]]></fr:tex> and <fr:tex
display="inline"><![CDATA[g\colon  B\rightarrowtail  C]]></fr:tex> be <fr:link
href="jms-00M0.xml"
title="The axiom of infinity"
addr="jms-00M0"
type="local">injections</fr:link>. To show that the <fr:link
href="jms-00KI.xml"
title="Closure of functions under identity and composition"
addr="jms-00KI"
type="local">composite function</fr:link> <fr:tex
display="inline"><![CDATA[g\circ  f\colon  A\to  C]]></fr:tex> is <fr:link
href="jms-00MO.xml"
title="Injection"
addr="jms-00MO"
type="local">injective</fr:link>, we fix <fr:tex
display="inline"><![CDATA[a_0,a_1\in  A]]></fr:tex> to check that <fr:tex
display="inline"><![CDATA[g{\mathopen {}\left (f{\mathopen {}\left (a_0\right )\mathclose {}}\right )\mathclose {}} = g{\mathopen {}\left (f{\mathopen {}\left (a_1\right )\mathclose {}}\right )\mathclose {}}]]></fr:tex> implies <fr:tex
display="inline"><![CDATA[a_0=a_1]]></fr:tex>. Because <fr:tex
display="inline"><![CDATA[g]]></fr:tex> is <fr:link
href="jms-00MO.xml"
title="Injection"
addr="jms-00MO"
type="local">injective</fr:link>, we have <fr:tex
display="inline"><![CDATA[f{\mathopen {}\left (a_0\right )\mathclose {}}=f{\mathopen {}\left (a_1\right )\mathclose {}}]]></fr:tex>; therefore, because <fr:tex
display="inline"><![CDATA[f]]></fr:tex> is <fr:link
href="jms-00MO.xml"
title="Injection"
addr="jms-00MO"
type="local">injective</fr:link>, we have <fr:tex
display="inline"><![CDATA[a_0=a_1]]></fr:tex> as desired.</fr:p>
</fr:mainmatter></fr:tree>
 
