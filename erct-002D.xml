root="false"><fr:frontmatter><fr:anchor>7988</fr:anchor><fr:taxon>Definition</fr:taxon><fr:addr>erct-000X</fr:addr><fr:route>erct-000X.xml</fr:route><fr:title>Quasi-inverse</fr:title><fr:date><fr:year>2023</fr:year><fr:month>12</fr:month><fr:day>19</fr:day></fr:date><fr:authors><fr:author><fr:link
href="jonmsterling.xml"
type="local"
addr="jonmsterling">Jon Sterling</fr:link></fr:author></fr:authors><fr:meta
