type="local"
href="jms-00KF.xml"
addr="jms-00KF"
title="Function">function</fr:link> <fr:tex
display="inline"><![CDATA[!_A\colon  A\to  {\mathopen {}\left  [1\right  ]\mathclose {}}]]></fr:tex> is <fr:link
type="local"
href="jms-00M8.xml"
addr="jms-00M8"
title="Surjection">surjective</fr:link> if and only if <fr:tex
display="inline"><![CDATA[A \not =\varnothing ]]></fr:tex>.</fr:p>
 
   
   <fr:tree
