                <fr:taxon>Corollary</fr:taxon>
              </fr:frontmatter>
              <fr:mainmatter><fr:p>Any <fr:link href="jms-00KR.xml" title="Bijection" addr="jms-00KR" type="local">bijection</fr:link> <fr:tex display="inline"><![CDATA[f\colon  A\to  B]]></fr:tex> is <fr:link href="jms-00M8.xml" title="Surjection" addr="jms-00M8" type="local">surjective</fr:link>.</fr:p>
 
   
   <fr:tree show-metadata="false" toc="false"><fr:frontmatter><fr:authors><fr:author><fr:link href="jonmsterling.xml" title="Jon Sterling" addr="jonmsterling" type="local">Jon Sterling</fr:link></fr:author></fr:authors><fr:date><fr:year>2024</fr:year><fr:month>1</fr:month><fr:day>29</fr:day></fr:date><fr:anchor>6859</fr:anchor><fr:addr type="machine">unstable/6044</fr:addr><fr:route>unstable-6044.xml</fr:route><fr:title text="" /><fr:taxon>Proof</fr:taxon></fr:frontmatter><fr:mainmatter>
 <fr:p>By <fr:link href="jms-00M7.xml" title="Logical characterisation of bijections" addr="jms-00M7" type="local">Theorem <fr:contextual-number addr="jms-00M7" /></fr:link>.</fr:p>
