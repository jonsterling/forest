addr="larsbirkedal">Lars Birkedal</fr:link></fr:author></fr:authors><fr:parent>jms-00OI</fr:parent></fr:frontmatter><fr:mainmatter><fr:p>We add two additional rules to the equational theory of guarded higher-order dynamic allocation.</fr:p><beamer:pause
xmlns:beamer="http://ctan.org/pkg/beamer"></beamer:pause><fr:p><fr:strong>LAYOUT UNIVALENCE.</fr:strong></fr:p>
 <jms-indent:block
xmlns:jms-indent="jonmsterling:indenting">
  
 <jms-indent:row>
   <fr:tex>     {\mathopen {}\left (      \ell _1\gets \mathsf {new}\,e_1;      \ell _2\gets \mathsf {new}\,e_2;      \mathsf {ret}\,{\mathopen {}\left (\ell _1,\ell _2\right )\mathclose {}}     \right )\mathclose {}}    </fr:tex>
  </jms-indent:row>

  
 <jms-indent:block>
   <fr:tex>     \mathrel {\equiv }     {\mathopen {}\left (      \ell _{\color {red}2}\gets \mathsf {new}\,e_{\color {red}2};      \ell _{\color {red}1}\gets \mathsf {new}\,e_{\color {red}1};      \mathsf {ret}\,{\mathopen {}\left (\ell _1,\ell _2\right )\mathclose {}}     \right )\mathclose {}}    </fr:tex>
  </jms-indent:block>

 </jms-indent:block>
<beamer:pause
xmlns:beamer="http://ctan.org/pkg/beamer"></beamer:pause><fr:p><fr:strong>CELL UNIVALENCE.</fr:strong> For <fr:tex>f^+\colon  A\to  B</fr:tex> and <fr:tex>f^-\colon  B\to  A</fr:tex> with <fr:tex>x:B\vdash  f^+{\mathopen {}\left (f^-{\mathopen {}\left (x\right )\mathclose {}}\right )\mathclose {}}\equiv  x</fr:tex> and <fr:tex>x\colon  A\vdash  f^-{\mathopen {}\left (f^+{\mathopen {}\left (x\right )\mathclose {}}\right )\mathclose {}} \equiv  x</fr:tex> we have:</fr:p>
 <jms-indent:block
xmlns:jms-indent="jonmsterling:indenting">
  
 <jms-indent:row>
   <fr:tex>     {\mathopen {}\left (      \ell \gets \mathsf {new}\,e;      \mathsf {ret}\,{\mathopen {}\left (\mathsf {get}\,\ell , \mathsf {set}\,{\mathopen {}\left (\ell ,-\right )\mathclose {}}\right )\mathclose {}}     \right )\mathclose {}}    </fr:tex>
  </jms-indent:row>

  
 <jms-indent:block>
   <fr:tex>     \mathrel {\equiv }     {\mathopen {}\left (      \ell \gets \mathsf {new}\,{\mathopen {}\left ({\color {red}f^+}{\mathopen {}\left (e\right )\mathclose {}}\right )\mathclose {}};      \mathsf {ret}\,{\mathopen {}\left (       {\color {red}\mathsf {map}\,f^-}\,{\mathopen {}\left (\mathsf {get}\,\ell \right )\mathclose {}},       \mathsf {set}{\mathopen {}\left (\ell , {\color {red}f^+}{\mathopen {}\left (-\right )\mathclose {}}\right )\mathclose {}}      \right )\mathclose {}}     \right )\mathclose {}}    </fr:tex>
  </jms-indent:block>

 </jms-indent:block>
</fr:mainmatter></fr:tree><fr:tree
