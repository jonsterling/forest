type="local"
addr="larsbirkedal">Lars Birkedal</fr:link></fr:author></fr:authors><fr:parent>jms-00OI</fr:parent></fr:frontmatter><fr:mainmatter><fr:p>Consider two implementations of an “counter” object:</fr:p>
 <jms-indent:block
xmlns:jms-indent="jonmsterling:indenting">
  
 <jms-indent:row>
   <fr:tex>     \mathsf {Counter} :\equiv  {\mathopen {}\left \{      \mathsf {incr}\colon  \mathsf {T}\,{\mathopen {}\left (\right )\mathclose {}};      \mathsf {read}\colon  \mathsf {T}\,\mathsf {Integer}     \right \}\mathclose {}}    </fr:tex>
  </jms-indent:row>


  
 <jms-indent:row></jms-indent:row>


  
 <jms-indent:row><fr:tex>\mathsf {posCounter} :\equiv </fr:tex></jms-indent:row>

  
 <jms-indent:block>
   
 <jms-indent:row><fr:tex>\ell \gets \mathsf {new}\,0;</fr:tex></jms-indent:row>

   
 <jms-indent:row><fr:tex>\mathsf {ret}\,\lbrace </fr:tex></jms-indent:row>

   
 <jms-indent:block>
    
 <jms-indent:row><fr:tex>\mathsf {incr}\hookrightarrow  i\gets \mathsf {get}\,\ell ; \mathsf {set}\,{\mathopen {}\left (\ell ,i+1\right )\mathclose {}};</fr:tex></jms-indent:row>

    
 <jms-indent:row><fr:tex>\mathsf {read}\hookrightarrow  \mathsf {get}\,\ell </fr:tex></jms-indent:row>

   </jms-indent:block>

   
 <jms-indent:row><fr:tex>\rbrace </fr:tex></jms-indent:row>

  </jms-indent:block>


  
 <jms-indent:row></jms-indent:row>


  
 <jms-indent:row><fr:tex>\mathsf {negCounter} :\equiv </fr:tex></jms-indent:row>

  
 <jms-indent:block>
   
 <jms-indent:row><fr:tex>\ell \gets \mathsf {new}\,0;</fr:tex></jms-indent:row>

   
 <jms-indent:row><fr:tex>\mathsf {ret}\,\lbrace </fr:tex></jms-indent:row>

   
 <jms-indent:block>
    
 <jms-indent:row><fr:tex>\mathsf {incr}\hookrightarrow  i\gets \mathsf {get}\,\ell ; \mathsf {set}\,{\mathopen {}\left (\ell ,i-1\right )\mathclose {}};</fr:tex></jms-indent:row>

    
 <jms-indent:row><fr:tex>\mathsf {read}\hookrightarrow  \mathsf {map}\,\mathsf {neg}\,{\mathopen {}\left (\mathsf {get}\,\ell \right )\mathclose {}}</fr:tex></jms-indent:row>

   </jms-indent:block>

   
 <jms-indent:row><fr:tex>\rbrace </fr:tex></jms-indent:row>

  </jms-indent:block>

 </jms-indent:block>
</fr:mainmatter></fr:tree><fr:tree
