type="local"
addr="larsbirkedal">Lars Birkedal</fr:link></fr:author></fr:authors><fr:parent>jms-00OI</fr:parent></fr:frontmatter><fr:mainmatter><fr:p>An equational theory of higher-order store in which reads to the heap leave behind “breadcrumbs”.</fr:p>
 <jms-indent:block
xmlns:jms-indent="jonmsterling:indenting">
  
 <jms-indent:row><fr:tex>\mathsf {set}\,{\mathopen {}\left (e_1,e_2\right )\mathclose {}}; \mathsf {get}\,e_1</fr:tex></jms-indent:row>

  
 <jms-indent:block>
   <fr:tex>     \mathrel {\equiv }     {\color {red}\mathsf {step}};\mathsf {set}\,{\mathopen {}\left (e_1,e_2\right )\mathclose {}}; \mathsf {ret}\, e_2    </fr:tex>
  </jms-indent:block>


  
 <jms-indent:row><fr:tex>{\mathopen {}\left (\_\gets \mathsf {get}\,e_1; e_2\right )\mathclose {}}</fr:tex></jms-indent:row>

  
 <jms-indent:block><fr:tex>\mathrel {\equiv }{\color {red}\mathsf {step}};e_2</fr:tex></jms-indent:block>


  
 <jms-indent:row><fr:tex>{\mathopen {}\left (x\gets  \mathsf {new}\,e_1; \mathsf {set}\,{\mathopen {}\left (e_1,e_2\right )\mathclose {}};\mathsf {ret}\,x\right )\mathclose {}}</fr:tex></jms-indent:row>

  
 <jms-indent:block><fr:tex>\mathrel {\equiv } \mathsf {new}\,e_2</fr:tex></jms-indent:block>


  
 <jms-indent:row><fr:tex>\mathsf {set}\,{\mathopen {}\left (e_1,e_2\right )\mathclose {}};\mathsf {set}\,{\mathopen {}\left (e_1,e_3\right )\mathclose {}}</fr:tex></jms-indent:row>

  
 <jms-indent:block><fr:tex>\mathrel {\equiv } \mathsf {set}\,{\mathopen {}\left (e_1,e_3\right )\mathclose {}}</fr:tex></jms-indent:block>


  
 <jms-indent:row><fr:tex>{\mathopen {}\left (x\gets  \mathsf {get}\,e_1; y\gets  \mathsf {get}\,e_2; \mathsf {ret}\,{\mathopen {}\left (x,y\right )\mathclose {}}\right )\mathclose {}}</fr:tex></jms-indent:row>

  
 <jms-indent:block><fr:tex>\mathrel {\equiv }{\mathopen {}\left (y\gets  \mathsf {get}\,e_2; x\gets  \mathsf {get}\,e_1; \mathsf {ret}\,{\mathopen {}\left (x,y\right )\mathclose {}}\right )\mathclose {}}</fr:tex></jms-indent:block>


  
 <jms-indent:row><fr:tex>{\mathopen {}\left (x\gets  \mathsf {get}\,e; \mathsf {set}\,{\mathopen {}\left (e,x\right )\mathclose {}}; \mathsf {ret}\, x\right )\mathclose {}}</fr:tex></jms-indent:row>

  
 <jms-indent:block><fr:tex>\mathrel {\equiv } \mathsf {get}\,e</fr:tex></jms-indent:block>

 </jms-indent:block>
</fr:mainmatter></fr:tree><fr:tree
