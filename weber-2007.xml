text="Yoneda structures from 2-toposes">Yoneda structures from 2-toposes</fr:title><fr:taxon>Reference</fr:taxon><fr:date><fr:year>2007</fr:year><fr:month>5</fr:month><fr:day>3</fr:day></fr:date><fr:authors><fr:author><fr:link
