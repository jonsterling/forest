display="inline"><![CDATA[a_0=s]]></fr:tex>, <fr:tex
display="inline"><![CDATA[a_n=t]]></fr:tex>, and <fr:tex
display="inline"><![CDATA[a_i\mathrel {R}a_{i+1}]]></fr:tex> for all <fr:tex
display="inline"><![CDATA[0\leq  i <n]]></fr:tex>.</fr:p></fr:mainmatter><fr:backmatter /></fr:tree><fr:tree
