text="Directed graph">Directed graph</fr:title><fr:taxon>Definition</fr:taxon><fr:date><fr:year>2024</fr:year><fr:month>1</fr:month><fr:day>18</fr:day></fr:date><fr:authors><fr:author><fr:link
