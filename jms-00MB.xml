type="machine">unstable/6048</fr:addr><fr:route>unstable-6048.xml</fr:route><fr:title
text="" /><fr:taxon>Proof</fr:taxon></fr:frontmatter><fr:mainmatter>
 <fr:p>We will use the same method as in our proof of <fr:link
href="jms-00MI.xml"
title="Alternative definition of countability"
addr="jms-00MI"
type="local">Lemma <fr:contextual-number
addr="jms-00MI" /></fr:link>.</fr:p>
 <fr:p>Let <fr:tex
display="inline"><![CDATA[S\subseteq  A]]></fr:tex> be a non-empty subset of an <fr:link
href="jms-00ME.xml"
title="Enumerable set"
addr="jms-00ME"
type="local">enumerable</fr:link> set <fr:tex
display="inline"><![CDATA[A]]></fr:tex>, so that we have some <fr:tex
display="inline"><![CDATA[s\in  S]]></fr:tex> and a <fr:link
href="jms-00M8.xml"
title="Surjection"
addr="jms-00M8"
type="local">surjection</fr:link> <fr:tex
display="inline"><![CDATA[e\colon \mathbb {N}\twoheadrightarrow  A]]></fr:tex>. We define <fr:tex
display="inline"><![CDATA[e'\colon  \mathbb {N}\twoheadrightarrow {S}]]></fr:tex> to send <fr:tex
display="inline"><![CDATA[i\in \mathbb {N}]]></fr:tex> to <fr:tex
display="inline"><![CDATA[e{\mathopen {}\left (i\right )\mathclose {}}]]></fr:tex> if <fr:tex
display="inline"><![CDATA[e{\mathopen {}\left (i\right )\mathclose {}}\in  S]]></fr:tex> and to <fr:tex
display="inline"><![CDATA[s]]></fr:tex> otherwise.</fr:p>
</fr:mainmatter></fr:tree>
 
