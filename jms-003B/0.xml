            <fr:title text="Wild natural transformation">Wild natural transformation</fr:title>
            <fr:taxon>Definition</fr:taxon>
          </fr:frontmatter>
          <fr:mainmatter>
            <html:p>Let <fr:tex display="inline"><![CDATA[\mathcal {C},\mathcal {D}]]></fr:tex> be two <fr:link href="http://www.jonmsterling.com/jms-0037.xml" title="Wild category" addr="jms-0037" type="local">wild categories</fr:link>, and let <fr:tex display="inline"><![CDATA[F,G:\mathcal {C}\to \mathcal {D}]]></fr:tex> be two
  <fr:link href="http://www.jonmsterling.com/jms-0038.xml" title="Wild 0-functor" addr="jms-0038" type="local">wild 0-functors</fr:link> from <fr:tex display="inline"><![CDATA[\mathcal {C}]]></fr:tex> to <fr:tex display="inline"><![CDATA[\mathcal {D}]]></fr:tex>. A <html:em>wild natural transformation</html:em> is defined by the following data:</html:p>
            <html:ol><html:li>for each <fr:tex display="inline"><![CDATA[A:\mathbf {ob}_{\mathcal {C}}]]></fr:tex>, an element <fr:tex display="inline"><![CDATA[\alpha _{A} : \mathbf {hom}_{\mathcal {D}}{\mathopen {}\left (\mathbf {ob}_{F}A,\mathbf {ob}_{G}A\right )\mathclose {}}]]></fr:tex>;</html:li>
  <html:li>for each <fr:tex display="inline"><![CDATA[f:\mathbf {hom}_{\mathcal {C}}{\mathopen {}\left (A,B\right )\mathclose {}}]]></fr:tex>, an identification <fr:tex display="inline"><![CDATA[\alpha _{f} : \alpha _A; \mathbf {hom}_{G}{f} = \mathbf {hom}_{F}{f};\alpha _B]]></fr:tex>.</html:li></html:ol>
          </fr:mainmatter>
        </fr:tree>
        <fr:tree show-metadata="true" expanded="false" toc="false" numbered="false">
          <fr:frontmatter>
            <fr:authors>
              <fr:author>
                <fr:link href="http://www.jonmsterling.com/jonmsterling.xml" title="Jon Sterling" addr="jonmsterling" type="local">Jon Sterling</fr:link>
              </fr:author>
            </fr:authors>
            <fr:date>
              <fr:year>2023</fr:year>
              <fr:month>3</fr:month>
              <fr:day>14</fr:day>
            </fr:date>
            <fr:addr>jms-0037</fr:addr>
            <fr:route>http://www.jonmsterling.com/jms-0037.xml</fr:route>
            <fr:title text="Wild category">Wild category</fr:title>
            <fr:taxon>Definition</fr:taxon>
          </fr:frontmatter>
          <fr:mainmatter>
            <html:p>A <html:em>wild category</html:em> is given by the following data:</html:p>
            <html:ol><html:li>a type <fr:tex display="inline"><![CDATA[\mathbf {ob}_{\mathcal {C}}]]></fr:tex>;</html:li>
  <html:li>for each <fr:tex display="inline"><![CDATA[A,B:\mathbf {ob}_{\mathcal {C}}]]></fr:tex>, a family of types <fr:tex display="inline"><![CDATA[\mathbf {hom}_{\mathcal {C}}{\mathopen {}\left (A,B\right )\mathclose {}}]]></fr:tex>;</html:li>
  <html:li>for each <fr:tex display="inline"><![CDATA[A:\mathbf {ob}_{\mathcal {C}}]]></fr:tex>, an element <fr:tex display="inline"><![CDATA[1_{A} : \mathbf {hom}_{\mathcal {C}}{\mathopen {}\left (A,A\right )\mathclose {}}]]></fr:tex>;</html:li>
  <html:li>for each <fr:tex display="inline"><![CDATA[f:\mathbf {hom}_{\mathcal {C}}{\mathopen {}\left (A,B\right )\mathclose {}}]]></fr:tex> and <fr:tex display="inline"><![CDATA[g:\mathbf {hom}_{\mathcal {C}}{\mathopen {}\left (B,C\right )\mathclose {}}]]></fr:tex>, an element <fr:tex display="inline"><![CDATA[{\mathopen {}\left (f;g\right )\mathclose {}} : \mathbf {hom}_{\mathcal {C}}{\mathopen {}\left (A,C\right )\mathclose {}}]]></fr:tex></html:li>
  <html:li>for each <fr:tex display="inline"><![CDATA[f:\mathbf {hom}_{\mathcal {C}}{\mathopen {}\left (A,B\right )\mathclose {}}]]></fr:tex>, a identification <fr:tex display="inline"><![CDATA[\mathsf {lunit}_{\mathcal {C}} f : {\mathopen {}\left (1_{A};f\right )\mathclose {}} = f]]></fr:tex> and a identification <fr:tex display="inline"><![CDATA[\mathsf {runit}_{\mathcal {C}} f : {\mathopen {}\left (f;1_{B}\right )\mathclose {}}=f]]></fr:tex>;</html:li>
  <html:li>for each <fr:tex display="inline"><![CDATA[f:\mathbf {hom}_{\mathcal {C}}{\mathopen {}\left (A,B\right )\mathclose {}}]]></fr:tex> and <fr:tex display="inline"><![CDATA[g:\mathbf {hom}_{\mathcal {C}}{\mathopen {}\left (B,C\right )\mathclose {}}]]></fr:tex> and <fr:tex display="inline"><![CDATA[h:\mathbf {hom}_{\mathcal {C}}{\mathopen {}\left (C,D\right )\mathclose {}}]]></fr:tex>, a identification <fr:tex display="inline"><![CDATA[\mathsf {assoc}_{\mathcal {C}}\,f\,g\,h : f;{\mathopen {}\left (g;h\right )\mathclose {}} = {\mathopen {}\left (f;g\right )\mathclose {}};h]]></fr:tex>.</html:li></html:ol>
          </fr:mainmatter>
