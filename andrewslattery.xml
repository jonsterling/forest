        <fr:tree show-metadata="true" expanded="false" toc="false" numbered="false">
          <fr:frontmatter>
            <fr:authors>
              <fr:author>
                <fr:link href="https://www.jonmsterling.com/andrewslattery.xml" title="Andrew Slattery" addr="andrewslattery" type="local">Andrew Slattery</fr:link>
              </fr:author>
              <fr:author>
                <fr:link href="https://www.jonmsterling.com/jonmsterling.xml" title="Jon Sterling" addr="jonmsterling" type="local">Jon Sterling</fr:link>
              </fr:author>
            </fr:authors>
            <fr:date>
              <fr:year>2025</fr:year>
