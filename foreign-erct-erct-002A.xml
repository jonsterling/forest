            <fr:title text="The truncation hierarchy › propositional truncation and existence"><fr:link href="foreign-erct-erct-001E.xml" title="The truncation hierarchy" addr="//erct/erct-001E" type="local">The truncation hierarchy</fr:link> › propositional truncation and existence</fr:title>
          </fr:frontmatter>
          <fr:mainmatter>
            <fr:tree show-metadata="false">
              <fr:frontmatter>
                <fr:authors>
