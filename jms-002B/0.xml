   <fr:tree show-metadata="false" toc="false"><fr:frontmatter><fr:authors><fr:author><fr:link href="https://www.jonmsterling.com/tomdejong.xml" title="Tom de Jong" addr="tomdejong" type="local">Tom de Jong</fr:link></fr:author><fr:author><fr:link href="https://www.jonmsterling.com/martinescardo.xml" title="Martín Hötzel Escardó" addr="martinescardo" type="local">Martín Hötzel Escardó</fr:link></fr:author><fr:author><fr:link href="https://www.jonmsterling.com/jonmsterling.xml" title="Jon Sterling" addr="jonmsterling" type="local">Jon Sterling</fr:link></fr:author></fr:authors><fr:date><fr:year>2023</fr:year><fr:month>2</fr:month><fr:day>16</fr:day></fr:date><fr:addr>jms-002B/0</fr:addr><fr:route>https://www.jonmsterling.com/jms-002B/0.xml</fr:route><fr:title text="liftedness = positive generation › forest://jonmsterling/jms-002B/0"><fr:link href="https://www.jonmsterling.com/jms-002B.xml" title="liftedness = positive generation" addr="jms-002B" type="local">liftedness = positive generation</fr:link> › jms-002B/0</fr:title><fr:taxon>Proof</fr:taxon></fr:frontmatter><fr:mainmatter>
