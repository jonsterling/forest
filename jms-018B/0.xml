            <fr:taxon>Theorem</fr:taxon>
          </fr:frontmatter>
          <fr:mainmatter><html:p>A <fr:link href="http://www.jonmsterling.com/jms-016M.xml" title="Formal language" addr="jms-016M" type="local">formal language</fr:link> is <fr:link href="http://www.jonmsterling.com/jms-017Y.xml" title="Regular language" addr="jms-017Y" type="local">regular</fr:link> if and only if it is <fr:link href="http://www.jonmsterling.com/jms-0185.xml" title="Automatical language" addr="jms-0185" type="local">automatical</fr:link>.</html:p>
 
   
