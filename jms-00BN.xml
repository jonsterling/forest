expanded="true"
root="false"><fr:frontmatter><fr:anchor>11291</fr:anchor><fr:taxon>Remark</fr:taxon><fr:addr>jms-00BX</fr:addr><fr:route>jms-00BX.xml</fr:route><fr:title>Rigid morphisms between computation paths</fr:title><fr:date><fr:year>2023</fr:year><fr:month>10</fr:month><fr:day>26</fr:day></fr:date><fr:authors><fr:author><fr:link
href="jonmsterling.xml"
type="local"
addr="jonmsterling">Jon Sterling</fr:link></fr:author></fr:authors></fr:frontmatter><fr:mainmatter><fr:p>A <fr:link
href="jms-00BW.xml"
type="local"
