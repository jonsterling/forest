root="false"><fr:frontmatter><fr:anchor>11382</fr:anchor><fr:addr>jms-00BQ</fr:addr><fr:route>jms-00BQ.xml</fr:route><fr:title>Notes on <fr:link
href="jms-00BN.xml"
type="local"
addr="jms-00BN">event structures</fr:link></fr:title><fr:date><fr:year>2023</fr:year><fr:month>10</fr:month><fr:day>26</fr:day></fr:date><fr:authors><fr:author><fr:link
href="jonmsterling.xml"
type="local"
addr="jonmsterling">Jon Sterling</fr:link></fr:author></fr:authors></fr:frontmatter><fr:mainmatter><fr:p>These notes are inspired and in large part derived from my reading of <fr:link
href="staton-winskel-2010.xml"
type="local"
addr="staton-winskel-2010">Staton and Winskel’s paper on event structures with symmetry</fr:link>.</fr:p><fr:tree
xmlns:fr="http://www.jonmsterling.com/jms-005P.xml"
