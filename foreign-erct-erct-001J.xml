            <fr:anchor>17563</fr:anchor>
            <fr:addr type="user">//erct/erct-001L</fr:addr>
            <fr:route>foreign-erct-erct-001L.xml</fr:route>
            <fr:title text="Propositions are sets"><fr:link href="foreign-erct-erct-001I.xml" title="Proposition" addr="//erct/erct-001I" type="local">Propositions</fr:link> are <fr:link href="foreign-erct-erct-001J.xml" title="Sets" addr="//erct/erct-001J" type="local">sets</fr:link></fr:title>
            <fr:taxon>Lemma</fr:taxon>
            <fr:meta name="source">
  
  
