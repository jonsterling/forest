root="false"><fr:frontmatter><fr:anchor>10932</fr:anchor><fr:taxon>Remark</fr:taxon><fr:addr>jms-00BX</fr:addr><fr:route>jms-00BX.xml</fr:route><fr:title>Rigid morphisms between computation paths</fr:title><fr:date><fr:year>2023</fr:year><fr:month>10</fr:month><fr:day>26</fr:day></fr:date><fr:authors><fr:author><fr:link
href="jonmsterling.xml"
type="local"
addr="jonmsterling">Jon Sterling</fr:link></fr:author></fr:authors></fr:frontmatter><fr:mainmatter><fr:p>A <fr:link
href="jms-00BW.xml"
type="local"
addr="jms-00BW">computation path</fr:link> is clearly same thing as a finite poset. A <fr:link
href="jms-00BR.xml"
type="local"
addr="jms-00BR">rigid morphism</fr:link> between computation paths corresponds, however, to a <fr:em>monomorphism</fr:em> of posets (not necessarily regular).</fr:p></fr:mainmatter></fr:tree></fr:mainmatter></fr:tree><fr:tree
