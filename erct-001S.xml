type="external">erct-0026.agda</fr:link>
</fr:meta></fr:frontmatter><fr:mainmatter><fr:p>If <fr:tex>B</fr:tex> is a <fr:link
href="erct-0025.xml"
type="local"
addr="erct-0025">retract</fr:link> of <fr:tex>A</fr:tex> and <fr:tex>A</fr:tex> is a <fr:link
href="erct-001I.xml"
type="local"
addr="erct-001I">proposition</fr:link>, then <fr:tex>B</fr:tex> is a <fr:link
href="erct-001I.xml"
type="local"
addr="erct-001I">proposition</fr:link>.</fr:p>
 
   
   <fr:tree
