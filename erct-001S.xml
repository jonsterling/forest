root="false"><fr:frontmatter><fr:anchor>6712</fr:anchor><fr:taxon>Definition</fr:taxon><fr:addr>erct-001I</fr:addr><fr:route>erct-001I.xml</fr:route><fr:title>Proposition</fr:title><fr:date><fr:year>2023</fr:year><fr:month>12</fr:month><fr:day>20</fr:day></fr:date><fr:authors><fr:author><fr:link
href="jonmsterling.xml"
type="local"
addr="jonmsterling">Jon Sterling</fr:link></fr:author></fr:authors><fr:meta
