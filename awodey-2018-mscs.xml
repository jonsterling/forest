  \DiagramSquare {
    height = 1.5cm,
    nw = A^V,
    sw = B^V,
    west = p^V,
    ne = A^U,
    se = B^U,
    east = p^U,
    south = B^f,
    north = A^f,
  }
  \qquad 
  \begin {tikzpicture}[diagram,baseline=(sq/sw.base)]
    \SpliceDiagramSquare <sq/>{
      ne = p^U,
      se = B^U,
      sw = A^U,
      nw = {\mathopen {}\left (f^U\right )\mathclose {}}^*p^U,
      south = f^U,
      north = h_{p^f},
      nw/style = pullback,
      west/style = lies over,
      east/style = lies over,
      north/node/style = upright desc,
      width = 2.5cm,
      height = 1.5cm,
    }
    \node [above = of sq/nw] (nw) {$p^V$};
    \draw [->] (nw) to node[sloped,above] {$p^f$} (sq/ne);
    \draw [->,exists] (nw) to node[upright desc] {$v_{p^f}$} (sq/nw);
  \end {tikzpicture}
]]></fr:resource-source></fr:resource></fr:figure>
 
<fr:p>A <fr:em>(weak, strong) left lifting structure</fr:em> for <fr:tex
display="inline"><![CDATA[{U}\xrightarrow {{l}}{V}]]></fr:tex> against <fr:tex
display="inline"><![CDATA[{A}\xrightarrow {{r}}{B}]]></fr:tex> is then defined to be a (section, inverse) to the vertical factor <fr:tex
display="inline"><![CDATA[{p^V}\xrightarrow {{v_{p^f}}}{{\mathopen {}\left (f^U\right )\mathclose {}}^*p^U}]]></fr:tex> in <fr:tex
display="inline"><![CDATA[{\mathcal {E}}_{/A^U}]]></fr:tex> depicted above — or equivalently a (section, inverse) to the underlying morphism in <fr:tex
display="inline"><![CDATA[\mathcal {E}]]></fr:tex> of the vertical factor.</fr:p></fr:mainmatter><fr:backmatter /></fr:tree><fr:tree
