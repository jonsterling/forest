            <fr:title text="Biinvertible maps are surjective › "><fr:link href="foreign-erct-erct-002X.xml" title="Biinvertible maps are surjective" addr="//erct/erct-002X" type="local"><fr:link href="foreign-erct-erct-000U.xml" title="Biinverse" addr="//erct/erct-000U" type="local">Biinvertible</fr:link> maps are <fr:link href="foreign-erct-erct-0029.xml" title="Surjection" addr="//erct/erct-0029" type="local">surjective</fr:link></fr:link> › </fr:title>
            <fr:taxon>Proof</fr:taxon>
