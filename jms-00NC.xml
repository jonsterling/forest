type="local"
href="jms-00ME.xml"
addr="jms-00ME"
title="Enumerable set">enumerable set</fr:link> and let <fr:tex
display="inline"><![CDATA[A]]></fr:tex> be a <fr:link
type="local"
href="jms-00N9.xml"
addr="jms-00N9"
title="Family of sets">family of sets</fr:link> indexed in <fr:tex
display="inline"><![CDATA[I]]></fr:tex> such that each <fr:tex
display="inline"><![CDATA[A_i]]></fr:tex> is <fr:link
type="local"
href="jms-00ME.xml"
addr="jms-00ME"
title="Enumerable set">enumerable</fr:link>. Then the disjoint union <fr:tex
display="inline"><![CDATA[A = \coprod _{i\in  I}A_i]]></fr:tex> is <fr:link
