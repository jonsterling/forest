text="Axiom scheme of replacement">Axiom scheme of replacement</fr:title><fr:taxon>Axiom</fr:taxon><fr:date><fr:year>2024</fr:year><fr:month>1</fr:month><fr:day>31</fr:day></fr:date><fr:authors><fr:author><fr:link
type="local"
href="jonmsterling.xml"
