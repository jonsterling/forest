            <fr:title text="regular language">regular <fr:link href="https://www.jonmsterling.com/jms-016M.xml" title="formal language" addr="jms-016M" type="local">language</fr:link></fr:title>
            <fr:taxon>Definition</fr:taxon>
          </fr:frontmatter>
          <fr:mainmatter>
            <html:p>A <fr:link href="https://www.jonmsterling.com/jms-016M.xml" title="formal language" addr="jms-016M" type="local">formal language</fr:link> is called <html:em><html:strong>regular</html:strong></html:em> if it is equal to <fr:tex display="inline"><![CDATA[\mathcal {L}{\mathopen {}\left (R\right )\mathclose {}}]]></fr:tex> for some <fr:link href="https://www.jonmsterling.com/jms-0179.xml" title="regular expressions (abstract syntax)" addr="jms-0179" type="local">regular expression</fr:link> <fr:tex display="inline"><![CDATA[R]]></fr:tex>.</html:p>
          </fr:mainmatter>
        </fr:tree>
        <fr:tree show-metadata="true" expanded="false" toc="false" numbered="false">
          <fr:frontmatter>
            <fr:authors>
              <fr:author>
                <fr:link href="https://www.jonmsterling.com/jonmsterling.xml" title="Jon Sterling" addr="jonmsterling" type="local">Jon Sterling</fr:link>
              </fr:author>
            </fr:authors>
