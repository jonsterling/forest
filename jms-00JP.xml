            <fr:title text="Adding matrices together">Adding <fr:link href="jms-00IS.xml" title="Matrix over a semiring" addr="jms-00IS" type="local">matrices</fr:link> together</fr:title>
          </fr:frontmatter>
          <fr:mainmatter>
            <fr:tree show-metadata="false">
              <fr:frontmatter>
                <fr:authors>
                  <fr:author>
                    <fr:link href="jonmsterling.xml" title="Jon Sterling" addr="jonmsterling" type="local">Jon Sterling</fr:link>
                  </fr:author>
                </fr:authors>
                <fr:date>
