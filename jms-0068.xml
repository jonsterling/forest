expanded="true"
root="false"><fr:frontmatter><fr:anchor>13539</fr:anchor><fr:taxon>Feature</fr:taxon><fr:addr>jms-0067</fr:addr><fr:route>jms-0067.xml</fr:route><fr:title><fr:link
href="jms-005V.xml"
type="local"
addr="jms-005V">Forester 2.2</fr:link> › flexible transclusion options</fr:title><fr:date><fr:year>2023</fr:year><fr:month>7</fr:month><fr:day>20</fr:day></fr:date><fr:authors><fr:author><fr:link
href="jonmsterling.xml"
type="local"
addr="jonmsterling">Jon Sterling</fr:link></fr:author></fr:authors><fr:parent>jms-005V</fr:parent></fr:frontmatter><fr:mainmatter><fr:p>This release replaces the old <fr:code>\transclude*</fr:code>, <fr:code>\transclude@</fr:code> commands with a more flexible transclusion configuration mechanism using the support for fluid binding introduced in <fr:link
href="jms-005O.xml"
type="local"
addr="jms-005O">Forester 2.1</fr:link>. A basic transclusion with the default options is done in the same way as before:</fr:p><fr:pre>\transclude{jms-0005}</fr:pre><fr:p>The behavior of transclusion is, however, configurable by several globally allocated fluid bindings as depicted in the <fr:link
href="jms-0069.xml"
type="local"
addr="jms-0069">table below</fr:link>.</fr:p>
  
  <fr:tree
xmlns:fr="http://www.jonmsterling.com/jms-005P.xml"
toc="true"
numbered="true"
show-heading="true"
show-metadata="false"
expanded="true"
root="false"><fr:frontmatter><fr:anchor>798</fr:anchor><fr:taxon>Table</fr:taxon><fr:addr>jms-0069</fr:addr><fr:route>jms-0069.xml</fr:route><fr:title>Transclusion options</fr:title><fr:authors><fr:author><fr:link
href="jonmsterling.xml"
type="local"
addr="jonmsterling">Jon Sterling</fr:link></fr:author></fr:authors><fr:parent>jms-0067</fr:parent></fr:frontmatter><fr:mainmatter>
  <html:table
xmlns:html="http://www.w3.org/1999/xhtml">
  
  
  <html:tr>
    
  <html:th>Fluid Binding</html:th>

    
  <html:th>Default</html:th>

    
  <html:th>Meaning</html:th>

  </html:tr>

  
  <html:tr>
    
  <html:td><fr:code>\transclude/title</fr:code></html:td>

    
  <html:td><fr:em>(none)</fr:em></html:td>

    
  <html:td>To override the tree's title during transclusion.</html:td>

  </html:tr>

  
  <html:tr>
    
  <html:td><fr:code>\transclude/toc</fr:code></html:td>

    
  <html:td><fr:code>true</fr:code></html:td>

    
  <html:td>Show the tree in the table of contents.</html:td>

  </html:tr>

  
  <html:tr>
    
  <html:td><fr:code>\transclude/expanded</fr:code></html:td>

    
  <html:td><fr:code>true</fr:code></html:td>

    
  <html:td>Whether the tree is expanded or not.</html:td>

  </html:tr>

  
  <html:tr>
    
  <html:td><fr:code>\transclude/heading</fr:code></html:td>

    
  <html:td><fr:code>true</fr:code></html:td>

    
  <html:td>If set to <fr:code>false</fr:code>, the tree's contents will be inlined.</html:td>

  </html:tr>

  
  <html:tr>
    
  <html:td><fr:code>\transclude/metadata</fr:code></html:td>

    
  <html:td><fr:code>false</fr:code></html:td>

    
  <html:td>Show in a tree's heading.</html:td>

  </html:tr>

  
  <html:tr>
    
  <html:td><fr:code>\transclude/numbered</fr:code></html:td>

    
  <html:td><fr:code>true</fr:code></html:td>

    
  <html:td>Whether the tree is displayed with a number or not, transitively on subtrees.</html:td>

  </html:tr>

</html:table>
<fr:p>It is possible to achieve undesirable results by combining these options in undesirable ways; it is up to you to use them correctly.</fr:p></fr:mainmatter></fr:tree>

  
