            <html:ul><html:li>Peter Aczel</html:li>
  <html:li><fr:link href="https://www.jonmsterling.com/benediktahrens.xml" title="Benedikt Ahrens" addr="benediktahrens" type="local">Benedikt Ahrens</fr:link></html:li>
