text="A type theory for synthetic ∞-categories">A type theory for synthetic ∞-categories</fr:title><fr:taxon>Reference</fr:taxon><fr:date><fr:year>2017</fr:year><fr:month>12</fr:month><fr:day>22</fr:day></fr:date><fr:authors><fr:author><fr:link
type="local"
