          </fr:frontmatter>
          <fr:mainmatter><fr:p>A <fr:link href="jms-001S.xml" title="Pointed dcpo" addr="jms-001S" type="local">pointed</fr:link> dcpo <fr:tex display="inline"><![CDATA[A]]></fr:tex> is lifted if and only if it is <fr:link href="jms-0023.xml" title="Positively generated dcpos" addr="jms-0023" type="local">positively generated</fr:link>.</fr:p>
 
   
   <fr:tree show-metadata="false" toc="false"><fr:frontmatter><fr:authors><fr:author><fr:link href="tomdejong.xml" title="Tom de Jong" addr="tomdejong" type="local">Tom de Jong</fr:link></fr:author><fr:author><fr:link href="martinescardo.xml" title="Martín Hötzel Escardó" addr="martinescardo" type="local">Martín Hötzel Escardó</fr:link></fr:author><fr:author><fr:link href="jonmsterling.xml" title="Jon Sterling" addr="jonmsterling" type="local">Jon Sterling</fr:link></fr:author></fr:authors><fr:date><fr:year>2023</fr:year><fr:month>2</fr:month><fr:day>16</fr:day></fr:date><fr:anchor>2314</fr:anchor><fr:addr type="machine">unstable/678</fr:addr><fr:route>unstable-678.xml</fr:route><fr:title text="" /><fr:taxon>Proof</fr:taxon></fr:frontmatter><fr:mainmatter>
