href="jms-00KF.xml"
title="Function"
addr="jms-00KF"
type="local">functions</fr:link> <fr:tex
display="inline"><![CDATA[s\colon  B \to  A]]></fr:tex> and <fr:tex
display="inline"><![CDATA[r\colon  A \to  B]]></fr:tex> such that <fr:tex
display="inline"><![CDATA[r\circ  s =\mathsf {id}_{B}]]></fr:tex>. In this case, <fr:tex
display="inline"><![CDATA[s]]></fr:tex> is referred to as a <fr:em><fr:strong>section</fr:strong></fr:em> of <fr:tex
display="inline"><![CDATA[r]]></fr:tex>, and <fr:tex
display="inline"><![CDATA[r]]></fr:tex> is referred to as a <fr:em><fr:strong>retraction</fr:strong></fr:em> of <fr:tex
display="inline"><![CDATA[s]]></fr:tex>.</fr:p></fr:mainmatter></fr:tree><fr:tree
